@page
@inject Microsoft.Extensions.Localization.IStringLocalizer<BodyLife.Crm.Web.Localization.Authentication> AuthenticationLocalizer
@{
    ViewData["Title"] = AuthenticationLocalizer["AccessDenied.Title"];
}

<main class="page-shell auth-shell">
    <section class="restricted-panel" aria-labelledby="access-denied-title">
        <p class="eyebrow">@AuthenticationLocalizer["AccessDenied.Eyebrow"]</p>
        <h1 id="access-denied-title">@AuthenticationLocalizer["AccessDenied.Heading"]</h1>
        <p>@AuthenticationLocalizer["AccessDenied.Message"]</p>
        <a class="secondary-link" asp-page="/Reception/Index">@AuthenticationLocalizer["AccessDenied.ReturnToReception"]</a>
    </section>
</main>
