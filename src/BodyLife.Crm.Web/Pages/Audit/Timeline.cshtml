@page
@model BodyLife.Crm.Web.Pages.Audit.TimelineModel
@{
    ViewData["Title"] = "Audit timeline";
    var timelinePage = Model.TimelinePage;
    var errorMessage = Model.LoadError ?? Model.Result?.ErrorMessage;
}

<main class="page-shell audit-page" data-audit-timeline-page>
    <section class="audit-layout" aria-labelledby="audit-timeline-title">
        <header class="report-header">
            <div>
                <p class="eyebrow">Business audit</p>
                <h1 id="audit-timeline-title">Audit timeline</h1>
            </div>
            <nav class="report-header-actions" aria-label="Audit navigation">
                <a class="secondary-link" asp-page="/Reports/Daily">Reports</a>
                <a class="secondary-link" asp-page="/Reception/Index">Reception</a>
            </nav>
        </header>

        <form class="audit-filter"
              method="get"
              asp-page="/Audit/Timeline"
              data-busy-form>
            <div class="audit-filter-grid">
                <div class="audit-filter-field">
                    <label for="audit-client-id">Client ID</label>
                    <input id="audit-client-id"
                           name="clientId"
                           type="text"
                           value="@Model.ClientId"
                           inputmode="text"
                           autocomplete="off" />
                </div>
                <div class="audit-filter-field">
                    <label for="audit-entity-type">Entity type</label>
                    <select id="audit-entity-type" name="entity">
                        <option value="">All entities</option>
                        @foreach (var option in TimelineModel.EntityOptions)
                        {
                            <option value="@option.Value"
                                    selected="@(Model.EntityType == option.Value ? "selected" : null)">
                                @option.Label
                            </option>
                        }
                    </select>
                </div>
                <div class="audit-filter-field">
                    <label for="audit-entity-id">Entity ID</label>
                    <input id="audit-entity-id"
                           name="entityId"
                           type="text"
                           value="@Model.EntityId"
                           inputmode="text"
                           autocomplete="off" />
                </div>
                <div class="audit-filter-field">
                    <label for="audit-recorded-from">Recorded from (UTC)</label>
                    <input id="audit-recorded-from"
                           name="from"
                           type="date"
                           value="@Model.RecordedFromDate?.ToString("yyyy-MM-dd")" />
                </div>
                <div class="audit-filter-field">
                    <label for="audit-recorded-to">Recorded through (UTC)</label>
                    <input id="audit-recorded-to"
                           name="to"
                           type="date"
                           value="@Model.RecordedToDate?.ToString("yyyy-MM-dd")" />
                </div>
                <div class="audit-filter-field">
                    <label for="audit-action-type">Business action</label>
                    <select id="audit-action-type" name="action">
                        <option value="">All actions</option>
                        @foreach (var option in TimelineModel.ActionOptions)
                        {
                            <option value="@option.Value"
                                    selected="@(Model.ActionType == option.Value ? "selected" : null)">
                                @option.Label
                            </option>
                        }
                    </select>
                </div>
            </div>
            <div class="audit-filter-actions">
                <button type="submit" data-busy-text="Loading...">Apply filters</button>
                <a class="secondary-link" asp-page="/Audit/Timeline">Clear</a>
            </div>
        </form>

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="warning-block warning-danger audit-error" role="alert">
                <strong>Audit timeline unavailable</strong>
                <span>@errorMessage</span>
            </div>
        }
        else if (timelinePage is not null)
        {
            <div class="audit-context" aria-label="Audit timeline selection">
                <span>
                    <strong>@timelinePage.Items.Count</strong>
                    entries shown
                </span>
                <span>
                    <strong>@Model.CurrentPageNumber</strong>
                    timeline page
                </span>
                <span>
                    <strong>@(timelinePage.EntityType is { } entityType ? TimelineModel.EntityLabel(entityType) : "All entities")</strong>
                    entity selection
                </span>
                <span>
                    <strong>@RecordedRangeLabel(Model.RecordedFromDate, Model.RecordedToDate)</strong>
                    recorded range
                </span>
            </div>

            <section class="audit-source-section" aria-labelledby="audit-results-title">
                <header class="report-section-header">
                    <div>
                        <p class="eyebrow">Append-only business events</p>
                        <h2 id="audit-results-title">Timeline entries</h2>
                    </div>
                    <span class="result-count">Newest recorded first</span>
                </header>

                @if (timelinePage.Items.Count == 0)
                {
                    <p class="empty-state">No audit entries match these filters.</p>
                }
                else
                {
                    <ol class="audit-entry-list" data-audit-entry-list>
                        @foreach (var entry in timelinePage.Items)
                        {
                            var explanation = AuditEntryExplanationViewModel.Create(entry);
                            <li class="audit-entry @TimelineModel.EntryClass(entry)"
                                data-audit-entry-id="@entry.AuditEntryId.Value"
                                data-action-type="@entry.ActionType"
                                data-entity-type="@entry.EntityType"
                                data-entry-origin="@entry.EntryOrigin"
                                data-account-kind="@entry.ActorAccountKind"
                                data-changed-after-close="@entry.ChangedAfterClose.ToString().ToLowerInvariant()">
                                <header class="audit-entry-header">
                                    <div>
                                        <p class="audit-entry-kind">
                                            @TimelineModel.EntityLabel(entry.EntityType)
                                            <span aria-hidden="true">/</span>
                                            @TimelineModel.ShortId(entry.EntityId)
                                        </p>
                                        <h3>@TimelineModel.ActionLabel(entry.ActionType)</h3>
                                    </div>
                                    <div class="audit-entry-flags">
                                        <span class="status-chip @TimelineModel.EntryOriginClass(entry.EntryOrigin)">
                                            @TimelineModel.EntryOriginLabel(entry.EntryOrigin)
                                        </span>
                                        @if (entry.ChangedAfterClose)
                                        {
                                            <span class="status-chip audit-changed-after-close">
                                                Changed after close
                                            </span>
                                        }
                                    </div>
                                </header>

                                <dl class="audit-entry-meta">
                                    <div>
                                        <dt>Occurred</dt>
                                        <dd>@TimelineModel.TimestampLabel(entry.OccurredAt)</dd>
                                    </div>
                                    <div>
                                        <dt>Recorded</dt>
                                        <dd>@TimelineModel.TimestampLabel(entry.RecordedAt)</dd>
                                    </div>
                                    <div>
                                        <dt>Actor account</dt>
                                        <dd>@TimelineModel.AccountKindLabel(entry.ActorAccountKind)</dd>
                                    </div>
                                    <div>
                                        <dt>Role</dt>
                                        <dd>@TimelineModel.RoleLabel(entry.ActorRole)</dd>
                                    </div>
                                    <div>
                                        <dt>Device</dt>
                                        <dd>@(entry.DeviceLabel ?? "No device label")</dd>
                                    </div>
                                    <div>
                                        <dt>Session</dt>
                                        <dd>@TimelineModel.ShortId(entry.SessionId.Value)</dd>
                                    </div>
                                </dl>

                                @if (!string.IsNullOrWhiteSpace(entry.Reason))
                                {
                                    <div class="audit-entry-note audit-entry-reason">
                                        <strong>Reason</strong>
                                        <span>@entry.Reason</span>
                                    </div>
                                }
                                @if (!string.IsNullOrWhiteSpace(entry.Comment))
                                {
                                    <div class="audit-entry-note">
                                        <strong>Comment</strong>
                                        <span>@entry.Comment</span>
                                    </div>
                                }

                                @if (explanation is not null)
                                {
                                    <section class="audit-change-explanation @(explanation.IsAvailable ? string.Empty : "audit-change-explanation-unavailable")"
                                             aria-label="Business change explanation"
                                             data-audit-change-explanation
                                             data-explanation-kind="@explanation.Kind"
                                             data-explanation-available="@explanation.IsAvailable.ToString().ToLowerInvariant()">
                                        <header>
                                            <p class="eyebrow">Business change</p>
                                            <h4>@explanation.Title</h4>
                                        </header>
                                        <p class="audit-change-narrative">@explanation.Narrative</p>

                                        @if (explanation.IsAvailable)
                                        {
                                            <div class="audit-change-columns">
                                                <section aria-label="@explanation.BeforeLabel">
                                                    <h5>@explanation.BeforeLabel</h5>
                                                    <dl class="audit-change-facts">
                                                        @foreach (var fact in explanation.BeforeFacts)
                                                        {
                                                            <div>
                                                                <dt>@fact.Label</dt>
                                                                <dd>@fact.Value</dd>
                                                            </div>
                                                        }
                                                    </dl>
                                                </section>
                                                <section aria-label="@explanation.AfterLabel">
                                                    <h5>@explanation.AfterLabel</h5>
                                                    <dl class="audit-change-facts">
                                                        @foreach (var fact in explanation.AfterFacts)
                                                        {
                                                            <div>
                                                                <dt>@fact.Label</dt>
                                                                <dd>@fact.Value</dd>
                                                            </div>
                                                        }
                                                    </dl>
                                                </section>
                                            </div>

                                            @if (!string.IsNullOrWhiteSpace(explanation.ChangedFields))
                                            {
                                                <p class="audit-change-fields">
                                                    <strong>Changed fields</strong>
                                                    <span>@explanation.ChangedFields</span>
                                                </p>
                                            }
                                        }
                                    </section>
                                }

                                <details class="audit-envelope-details">
                                    <summary>Audit envelope</summary>
                                    <dl class="audit-envelope-meta">
                                        <div>
                                            <dt>Audit entry ID</dt>
                                            <dd><code>@entry.AuditEntryId.Value</code></dd>
                                        </div>
                                        <div>
                                            <dt>Entity ID</dt>
                                            <dd><code>@entry.EntityId</code></dd>
                                        </div>
                                        <div>
                                            <dt>Actor account ID</dt>
                                            <dd><code>@entry.ActorAccountId.Value</code></dd>
                                        </div>
                                        <div>
                                            <dt>Session ID</dt>
                                            <dd><code>@entry.SessionId.Value</code></dd>
                                        </div>
                                        <div>
                                            <dt>Request correlation ID</dt>
                                            <dd><code>@entry.RequestCorrelationId.Value</code></dd>
                                        </div>
                                        <div>
                                            <dt>Idempotency key</dt>
                                            <dd><code>@(entry.IdempotencyKey ?? "Not used")</code></dd>
                                        </div>
                                    </dl>
                                    <div class="audit-json-grid">
                                        <section>
                                            <h4>Related records</h4>
                                            <pre><code>@TimelineModel.FormatJson(entry.RelatedEntityRefsJson)</code></pre>
                                        </section>
                                        <section>
                                            <h4>Before summary</h4>
                                            <pre><code>@TimelineModel.FormatJson(entry.BeforeSummaryJson)</code></pre>
                                        </section>
                                        <section>
                                            <h4>After summary</h4>
                                            <pre><code>@TimelineModel.FormatJson(entry.AfterSummaryJson)</code></pre>
                                        </section>
                                    </div>
                                </details>
                            </li>
                        }
                    </ol>
                }

                @if (Model.PreviousOffset is not null || timelinePage.NextOffset is not null)
                {
                    <nav class="report-pagination" aria-label="Audit timeline pages">
                        <span class="report-pagination-slot">
                            @if (Model.PreviousOffset is { } previousOffset)
                            {
                                <a class="secondary-link"
                                   asp-page="/Audit/Timeline"
                                   asp-route-clientId="@Model.ClientId"
                                   asp-route-entity="@Model.EntityType"
                                   asp-route-entityId="@Model.EntityId"
                                   asp-route-from="@Model.RecordedFromDate?.ToString("yyyy-MM-dd")"
                                   asp-route-to="@Model.RecordedToDate?.ToString("yyyy-MM-dd")"
                                   asp-route-action="@Model.ActionType"
                                   asp-route-offset="@previousOffset">
                                    Previous
                                </a>
                            }
                        </span>
                        <span class="result-count">Page @Model.CurrentPageNumber</span>
                        <span class="report-pagination-slot report-pagination-next">
                            @if (timelinePage.NextOffset is { } nextOffset)
                            {
                                <a class="secondary-link"
                                   asp-page="/Audit/Timeline"
                                   asp-route-clientId="@Model.ClientId"
                                   asp-route-entity="@Model.EntityType"
                                   asp-route-entityId="@Model.EntityId"
                                   asp-route-from="@Model.RecordedFromDate?.ToString("yyyy-MM-dd")"
                                   asp-route-to="@Model.RecordedToDate?.ToString("yyyy-MM-dd")"
                                   asp-route-action="@Model.ActionType"
                                   asp-route-offset="@nextOffset">
                                    Next
                                </a>
                            }
                        </span>
                    </nav>
                }
            </section>
        }
    </section>
</main>

@functions {
    private static string RecordedRangeLabel(DateOnly? from, DateOnly? to)
    {
        return (from, to) switch
        {
            ({ } start, { } end) => $"{start:yyyy-MM-dd} to {end:yyyy-MM-dd}",
            ({ } start, null) => $"From {start:yyyy-MM-dd}",
            (null, { } end) => $"Through {end:yyyy-MM-dd}",
            _ => "All recorded dates",
        };
    }
}
