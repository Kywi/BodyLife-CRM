@page
@model BodyLife.Crm.Web.Pages.Audit.TimelineModel
@{ var P = Model.Presentation; ViewData["Title"] = P.Text("Timeline.Title"); var timelinePage = Model.TimelinePage; var errorMessage = Model.LoadError ?? (Model.Result is null || timelinePage is not null ? null : P.TimelineError(Model.Result.Status)); }
<main class="page-shell audit-page" data-audit-timeline-page>
 <section class="audit-layout" aria-labelledby="audit-timeline-title">
  <header class="report-header"><div><p class="eyebrow">@P.Text("BusinessAudit")</p><h1 id="audit-timeline-title">@P.Text("Timeline.Title")</h1></div><nav class="report-header-actions" aria-label="@P.Text("Navigation")"><a class="secondary-link" asp-page="/Reports/Daily">@P.Text("Navigation.Reports")</a><a class="secondary-link" asp-page="/Reception/Index">@P.Text("Navigation.Reception")</a></nav></header>
  <form class="audit-filter" method="get" asp-page="/Audit/Timeline" data-busy-form><div class="audit-filter-grid">
   <div class="audit-filter-field"><label for="audit-client-id">@P.Text("ClientId")</label><input id="audit-client-id" name="clientId" type="text" value="@Model.ClientId" inputmode="text" autocomplete="off" /></div>
   <div class="audit-filter-field"><label for="audit-entity-type">@P.Text("EntityType")</label><select id="audit-entity-type" name="entity"><option value="">@P.Text("AllEntities")</option>@foreach(var option in TimelineModel.EntityOptions){<option value="@option.Value" selected="@(Model.EntityType == option.Value ? "selected" : null)">@P.Text(option.Label)</option>}</select></div>
   <div class="audit-filter-field"><label for="audit-entity-id">@P.Text("EntityId")</label><input id="audit-entity-id" name="entityId" type="text" value="@Model.EntityId" inputmode="text" autocomplete="off" /></div>
   <div class="audit-filter-field"><label for="audit-recorded-from">@P.Text("RecordedFrom")</label><input id="audit-recorded-from" name="from" type="date" value="@Model.RecordedFromDate?.ToString("yyyy-MM-dd")" /></div><div class="audit-filter-field"><label for="audit-recorded-to">@P.Text("RecordedThrough")</label><input id="audit-recorded-to" name="to" type="date" value="@Model.RecordedToDate?.ToString("yyyy-MM-dd")" /></div>
   <div class="audit-filter-field"><label for="audit-action-type">@P.Text("BusinessAction")</label><select id="audit-action-type" name="action"><option value="">@P.Text("AllActions")</option>@foreach(var option in TimelineModel.ActionOptions){<option value="@option.Value" selected="@(Model.ActionType == option.Value ? "selected" : null)">@P.Text(option.Label)</option>}</select></div>
  </div><div class="audit-filter-actions"><button type="submit" data-busy-text="@P.Text("Loading")">@P.Text("Apply")</button><a class="secondary-link" asp-page="/Audit/Timeline">@P.Text("Filter.Clear")</a></div></form>
  @if (!string.IsNullOrWhiteSpace(errorMessage)){<div class="warning-block warning-danger audit-error" role="alert"><strong>@P.Text("TimelineUnavailable")</strong><span>@errorMessage</span></div>}
  else if(timelinePage is not null){<div class="audit-context" aria-label="@P.Text("Timeline.Title")"><span>@P.Entries(timelinePage.Items.Count)</span><span><strong>@Model.CurrentPageNumber</strong> @P.Text("TimelinePage")</span><span><strong>@(timelinePage.EntityType is { } t ? P.Entity(t) : P.Text("AllEntities"))</strong> @P.Text("EntitySelection")</span><span><strong>@P.DateRange(Model.RecordedFromDate, Model.RecordedToDate)</strong> @P.Text("RecordedRange")</span></div>
  <section class="audit-source-section" aria-labelledby="audit-results-title"><header class="report-section-header"><div><p class="eyebrow">@P.Text("AppendOnly")</p><h2 id="audit-results-title">@P.Text("TimelineEntries")</h2></div><span class="result-count">@P.Text("NewestFirst")</span></header>
  @if(timelinePage.Items.Count==0){<p class="empty-state">@P.Text("NoTimelineEntries")</p>}else{<ol class="audit-entry-list" data-audit-entry-list>@foreach(var entry in timelinePage.Items){var explanation=Model.ExplanationPresenter.Create(entry);<li class="audit-entry @P.EntryClass(entry.ChangedAfterClose, entry.EntryOrigin)" data-audit-entry-id="@entry.AuditEntryId.Value" data-action-type="@entry.ActionType" data-entity-type="@entry.EntityType" data-entry-origin="@entry.EntryOrigin" data-account-kind="@entry.ActorAccountKind" data-changed-after-close="@entry.ChangedAfterClose.ToString().ToLowerInvariant()"><header class="audit-entry-header"><div><p class="audit-entry-kind">@P.Entity(entry.EntityType)<span aria-hidden="true">/</span>@P.ShortId(entry.EntityId)</p><h3>@P.Action(entry.ActionType)</h3></div><div class="audit-entry-flags"><span class="status-chip @P.EntryOriginClass(entry.EntryOrigin)">@P.EntryOrigin(entry.EntryOrigin)</span>@if(entry.ChangedAfterClose){<span class="status-chip audit-changed-after-close">@P.Text("ChangedAfterClose")</span>}</div></header>
  <dl class="audit-entry-meta"><div><dt>@P.Text("Meta.Occurred")</dt><dd>@P.Timestamp(entry.OccurredAt)</dd></div><div><dt>@P.Text("Meta.Recorded")</dt><dd>@P.Timestamp(entry.RecordedAt)</dd></div><div><dt>@P.Text("ActorAccount")</dt><dd>@P.AccountKind(entry.ActorAccountKind)</dd></div><div><dt>@P.Text("Meta.Role")</dt><dd>@P.Role(entry.ActorRole)</dd></div><div><dt>@P.Text("Meta.Device")</dt><dd>@(entry.DeviceLabel ?? P.Text("NoDevice"))</dd></div><div><dt>@P.Text("Meta.Session")</dt><dd>@P.ShortId(entry.SessionId.Value)</dd></div></dl>
  @if(!string.IsNullOrWhiteSpace(entry.Reason)){<div class="audit-entry-note audit-entry-reason"><strong>@P.Text("Meta.Reason")</strong><span>@entry.Reason</span></div>}@if(!string.IsNullOrWhiteSpace(entry.Comment)){<div class="audit-entry-note"><strong>@P.Text("Meta.Comment")</strong><span>@entry.Comment</span></div>}
  @if(explanation is not null){<section class="audit-change-explanation @(explanation.IsAvailable ? string.Empty : "audit-change-explanation-unavailable")" aria-label="@P.Text("BusinessChange")" data-audit-change-explanation data-explanation-kind="@explanation.Kind" data-explanation-available="@explanation.IsAvailable.ToString().ToLowerInvariant()"><header><p class="eyebrow">@P.Text("BusinessChange")</p><h4>@explanation.Title</h4></header><p class="audit-change-narrative">@explanation.Narrative</p>@if(explanation.IsAvailable){<div class="audit-change-columns"><section aria-label="@explanation.BeforeLabel"><h5>@explanation.BeforeLabel</h5><dl class="audit-change-facts">@foreach(var fact in explanation.BeforeFacts){<div><dt>@fact.Label</dt><dd>@fact.Value</dd></div>}</dl></section><section aria-label="@explanation.AfterLabel"><h5>@explanation.AfterLabel</h5><dl class="audit-change-facts">@foreach(var fact in explanation.AfterFacts){<div><dt>@fact.Label</dt><dd>@fact.Value</dd></div>}</dl></section></div>@if(!string.IsNullOrWhiteSpace(explanation.ChangedFields)){<p class="audit-change-fields"><strong>@P.Text("ChangedFields")</strong><span>@explanation.ChangedFields</span></p>}}</section>}
  <details class="audit-envelope-details"><summary>@P.Text("Envelope")</summary><dl class="audit-envelope-meta"><div><dt>@P.Text("AuditEntryId")</dt><dd><code>@entry.AuditEntryId.Value</code></dd></div><div><dt>@P.Text("EntityId")</dt><dd><code>@entry.EntityId</code></dd></div><div><dt>@P.Text("ActorAccountId")</dt><dd><code>@entry.ActorAccountId.Value</code></dd></div><div><dt>@P.Text("Meta.Session")</dt><dd><code>@entry.SessionId.Value</code></dd></div><div><dt>@P.Text("RequestCorrelationId")</dt><dd><code>@entry.RequestCorrelationId.Value</code></dd></div><div><dt>@P.Text("IdempotencyKey")</dt><dd><code>@(entry.IdempotencyKey??P.Text("NotUsed"))</code></dd></div></dl><div class="audit-json-grid"><section><h4>@P.Text("RelatedRecords")</h4><pre><code>@P.Json(entry.RelatedEntityRefsJson)</code></pre></section><section><h4>@P.Text("BeforeSummary")</h4><pre><code>@P.Json(entry.BeforeSummaryJson)</code></pre></section><section><h4>@P.Text("AfterSummary")</h4><pre><code>@P.Json(entry.AfterSummaryJson)</code></pre></section></div></details></li>}</ol>}
  @if(Model.PreviousOffset is not null||timelinePage.NextOffset is not null){<nav class="report-pagination" aria-label="@P.Text("TimelinePages")"><span class="report-pagination-slot">@if(Model.PreviousOffset is { } previousOffset){<a class="secondary-link" asp-page="/Audit/Timeline" asp-route-clientId="@Model.ClientId" asp-route-entity="@Model.EntityType" asp-route-entityId="@Model.EntityId" asp-route-from="@Model.RecordedFromDate?.ToString("yyyy-MM-dd")" asp-route-to="@Model.RecordedToDate?.ToString("yyyy-MM-dd")" asp-route-action="@Model.ActionType" asp-route-offset="@previousOffset">@P.Text("Pagination.Previous")</a>}</span><span class="result-count">@P.Text("Page",Model.CurrentPageNumber)</span><span class="report-pagination-slot report-pagination-next">@if(timelinePage.NextOffset is { } nextOffset){<a class="secondary-link" asp-page="/Audit/Timeline" asp-route-clientId="@Model.ClientId" asp-route-entity="@Model.EntityType" asp-route-entityId="@Model.EntityId" asp-route-from="@Model.RecordedFromDate?.ToString("yyyy-MM-dd")" asp-route-to="@Model.RecordedToDate?.ToString("yyyy-MM-dd")" asp-route-action="@Model.ActionType" asp-route-offset="@nextOffset">@P.Text("Pagination.Next")</a>}</span></nav>}</section>}</section></main>
