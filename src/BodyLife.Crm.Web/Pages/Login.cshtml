@page
@model BodyLife.Crm.Web.Pages.LoginModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<BodyLife.Crm.Web.Localization.Authentication> AuthenticationLocalizer
@{
    ViewData["Title"] = AuthenticationLocalizer["Login.Title"];
}

<main class="page-shell auth-shell">
    <section class="auth-panel" aria-labelledby="login-title">
        <header class="reception-header">
            <p class="eyebrow">BodyLife CRM</p>
            <h1 id="login-title">@AuthenticationLocalizer["Login.Title"]</h1>
        </header>

        <form method="post" class="auth-form">
            <input type="hidden" asp-for="ReturnUrl" />
            <div asp-validation-summary="ModelOnly" class="validation-summary" role="alert"></div>

            <label asp-for="LoginName">@AuthenticationLocalizer["Login.NameLabel"]</label>
            <input asp-for="LoginName" type="text" autocomplete="username" placeholder="@AuthenticationLocalizer["Login.NamePlaceholder"]" />

            <label asp-for="Password">@AuthenticationLocalizer["Login.PasswordLabel"]</label>
            <input asp-for="Password" type="password" autocomplete="current-password" placeholder="@AuthenticationLocalizer["Login.PasswordPlaceholder"]" />

            <label asp-for="DeviceLabel">@AuthenticationLocalizer["Login.DeviceLabel"]</label>
            <input asp-for="DeviceLabel" type="text" autocomplete="off" placeholder="@AuthenticationLocalizer["Login.DevicePlaceholder"]" />

            <button type="submit">@AuthenticationLocalizer["Login.Submit"]</button>
        </form>
    </section>
</main>
