@page
@model BodyLife.Crm.Web.Pages.Reports.NegativeClientsModel
@using BodyLife.Crm.Web.Localization
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<BodyLife.Crm.Web.Localization.Reports> L
@inject IStringLocalizer<BodyLife.Crm.Web.Localization.Shared> S
@{
    ViewData["Title"] = L["Negative.Title"];
    var reportPage = Model.ReportPage;
    var errorMessage = Model.LoadError;
}

<main class="page-shell report-page" data-negative-clients-report-page>
    <section class="report-layout" aria-labelledby="negative-clients-title">
        <header class="report-header">
            <div>
                <p class="eyebrow">@L["Navigation.Reports"]</p><h1 id="negative-clients-title">@L["Negative.Title"]</h1>
            </div>
            <nav class="report-header-actions" aria-label="@L["Navigation"]"><a class="secondary-link" asp-page="/Reports/Daily">@L["Daily"]</a><a class="secondary-link" asp-page="/Reports/EndingSoon">@L["Ending"]</a><a class="secondary-link" asp-page="/Reports/LowRemaining">@L["Low"]</a><a class="secondary-link" asp-page="/Reports/InactiveClients">@L["Inactive"]</a><a class="secondary-link" asp-page="/Reception/Index">@L["Navigation.Reception"]</a>
            </nav>
        </header>

        <form class="report-filter"
              method="get"
              asp-page="/Reports/NegativeClients"
              data-busy-form>
            <div class="report-date-field">
                <label for="negative-clients-as-of">@L["AsOf"]</label>
                <input id="negative-clients-as-of"
                       name="asOf"
                       type="date"
                       value="@Model.AsOfDate?.ToString("yyyy-MM-dd")"
                       required />
            </div>
            <button type="submit" data-busy-text="@L["Loading"]">@L["Load"]</button>
        </form>

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="warning-block warning-danger report-error" role="alert">
                <strong>@L["Unavailable"]</strong>
                <span>@errorMessage</span>
            </div>
        }
        else if (reportPage is not null)
        {
            <div class="report-list-context" aria-label="@L["Negative.Selection"]">
                <span>
                    <strong>@ReportsPresentation.Date(reportPage.AsOfDate)</strong> @L["AsOf"]
                </span>
                <span>@WebPluralizer.Clients(S, reportPage.Items.Count)</span>
                <span>
                    <strong>@Model.CurrentPageNumber</strong>
                    @L["ReportPage"]
                </span>
            </div>

            <section class="report-source-section" aria-labelledby="negative-clients-results-title">
                <header class="report-section-header">
                    <div>
                        <p class="eyebrow">@L["CanonicalMemberships"]</p><h2 id="negative-clients-results-title">@L["NegativeBalances"]</h2>
                    </div>
                </header>

                @if (reportPage.Items.Count == 0)
                {
                    <p class="empty-state">@L["Negative.Empty"]</p>
                }
                else
                {
                    <ol class="report-row-list" data-negative-client-rows>
                        @foreach (var row in reportPage.Items)
                        {
                            <li class="report-row negative-client-row"
                                data-client-id="@row.ClientId"
                                data-membership-id="@row.MembershipId"
                                data-negative-balance="@row.NegativeBalance"
                                data-remaining-visits="@row.RemainingVisits"
                                data-first-negative-visit-id="@row.FirstNegativeVisitId"
                                data-first-negative-visit-date="@row.FirstNegativeVisitDate?.ToString("yyyy-MM-dd")"
                                data-effective-end="@row.EffectiveEndDate.ToString("yyyy-MM-dd")">
                                <header class="report-row-header">
                                    <div>
                                        <p class="report-row-kind">@row.MembershipTypeName</p>
                                        <h3>@row.ClientDisplayName</h3>
                                    </div>
                                    <div class="report-membership-heading">
                                        <strong>@VisitDebtLabel(row.NegativeBalance)</strong>
                                        <span class="status-chip status-canceled">@L["Status.Negative"]</span>
                                    </div>
                                </header>

                                <dl class="report-row-meta report-membership-meta">
                                    <div>
                                        <dt>@L["Client.Phone"]</dt><dd>@(row.ClientPhone ?? L["NoPhone"])</dd>
                                    </div>
                                    <div>
                                        <dt>@L["RemainingVisits"]</dt>
                                        <dd>@row.RemainingVisits</dd>
                                    </div>
                                    <div>
                                        <dt>@L["NegativeBalance"]</dt>
                                        <dd>@row.NegativeBalance</dd>
                                    </div>
                                    <div>
                                        <dt>@L["FirstNegativeVisit"]</dt>
                                        <dd>@FormatFirstNegativeDate(row.FirstNegativeVisitDate)</dd>
                                    </div>
                                    <div>
                                        <dt>@L["LastCountedVisit"]</dt>
                                        <dd>@FormatLastVisit(row.LastCountedVisitAt)</dd>
                                    </div>
                                    <div>
                                        <dt>@L["EffectiveEnd"]</dt><dd>@ReportsPresentation.Date(row.EffectiveEndDate)</dd>
                                    </div>
                                </dl>

                                @if (row.Warnings.Count > 0)
                                {
                                    <ul class="warning-chip-list report-warning-list"
                                        aria-label="@L["Warnings"]">
                                        @foreach (var warning in row.Warnings)
                                        {
                                            <li class="@WarningClass(warning.Severity)"
                                                data-membership-warning="@warning.Code">
                                                @ReportsPresentation.WarningMessage(L, warning.Code)
                                            </li>
                                        }
                                    </ul>
                                }

                                <footer class="report-row-actions">
                                    <a class="secondary-link"
                                       asp-page="/Reception/Index"
                                       asp-route-clientId="@row.ClientId"
                                       asp-fragment="membership-panel-title">
                                        @L["OpenClient"]
                                    </a>
                                    @if (row.FirstNegativeVisitId is not null)
                                    {
                                        <a class="secondary-link"
                                           asp-page="/Reception/Index"
                                           asp-route-clientId="@row.ClientId"
                                           asp-fragment="recent-visits-title">
                                            @L["ViewVisits"]
                                        </a>
                                    }
                                </footer>
                            </li>
                        }
                    </ol>
                }

                @if (Model.PreviousOffset is not null || reportPage.NextOffset is not null)
                {
                    <nav class="report-pagination" aria-label="@L["Negative.Pages"]">
                        <span class="report-pagination-slot">
                            @if (Model.PreviousOffset is { } previousOffset)
                            {
                                <a class="secondary-link"
                                   asp-page="/Reports/NegativeClients"
                                   asp-route-asOf="@reportPage.AsOfDate.ToString("yyyy-MM-dd")"
                                   asp-route-offset="@previousOffset">
                                    @L["Pagination.Previous"]
                                </a>
                            }
                        </span>
                        <span class="result-count">@string.Format(L["Page"], Model.CurrentPageNumber)</span>
                        <span class="report-pagination-slot report-pagination-next">
                            @if (reportPage.NextOffset is { } nextOffset)
                            {
                                <a class="secondary-link"
                                   asp-page="/Reports/NegativeClients"
                                   asp-route-asOf="@reportPage.AsOfDate.ToString("yyyy-MM-dd")"
                                   asp-route-offset="@nextOffset">
                                    @L["Pagination.Next"]
                                </a>
                            }
                        </span>
                    </nav>
                }
            </section>
        }
    </section>
</main>

@functions {
    private string VisitDebtLabel(int negativeBalance)
    {
        return WebPluralizer.Visits(S, negativeBalance);
    }

    private string FormatFirstNegativeDate(DateOnly? firstNegativeVisitDate)
    {
        return firstNegativeVisitDate is { } date ? ReportsPresentation.Date(date) : L["NotRecorded"];
    }

    private string FormatLastVisit(DateTimeOffset? lastCountedVisitAt)
    {
        return lastCountedVisitAt is { } timestamp
            ? ReportsPresentation.Timestamp(timestamp) : L["NoCountedVisits"];
    }

    private static string WarningClass(MembershipWarningSeverity severity)
    {
        return severity == MembershipWarningSeverity.Danger
            ? "warning-chip-danger"
            : "warning-chip-caution";
    }
}
