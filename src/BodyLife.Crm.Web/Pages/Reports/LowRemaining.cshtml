@page
@model BodyLife.Crm.Web.Pages.Reports.LowRemainingModel
@{
    ViewData["Title"] = "Memberships low on visits";
    var reportPage = Model.ReportPage;
    var errorMessage = Model.LoadError ?? Model.Result?.ErrorMessage;
}

<main class="page-shell report-page" data-low-remaining-report-page>
    <section class="report-layout" aria-labelledby="low-remaining-title">
        <header class="report-header">
            <div>
                <p class="eyebrow">Reports</p>
                <h1 id="low-remaining-title">Memberships low on visits</h1>
            </div>
            <nav class="report-header-actions" aria-label="Report navigation">
                <a class="secondary-link" asp-page="/Reports/Daily">Daily report</a>
                <a class="secondary-link" asp-page="/Reports/EndingSoon">Ending soon</a>
                <a class="secondary-link" asp-page="/Reception/Index">Reception</a>
            </nav>
        </header>

        <form class="report-filter report-list-filter"
              method="get"
              asp-page="/Reports/LowRemaining"
              data-busy-form>
            <div class="report-date-field">
                <label for="low-remaining-as-of">As-of date</label>
                <input id="low-remaining-as-of"
                       name="asOf"
                       type="date"
                       value="@Model.AsOfDate?.ToString("yyyy-MM-dd")"
                       required />
            </div>
            <div class="report-threshold-field">
                <label for="low-remaining-threshold">Remaining visits at most</label>
                <input id="low-remaining-threshold"
                       name="remaining"
                       type="number"
                       value="@Model.RemainingVisitsThreshold"
                       min="0"
                       required />
            </div>
            <button type="submit" data-busy-text="Loading...">Load report</button>
        </form>

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="warning-block warning-danger report-error" role="alert">
                <strong>Report unavailable</strong>
                <span>@errorMessage</span>
            </div>
        }
        else if (reportPage is not null)
        {
            <div class="report-list-context" aria-label="Low-remaining report selection">
                <span>
                    <strong>@reportPage.AsOfDate.ToString("yyyy-MM-dd")</strong>
                    as-of date
                </span>
                <span>
                    <strong>@reportPage.RemainingVisitsThreshold</strong>
                    remaining-visits threshold
                </span>
                <span>
                    <strong>@reportPage.Items.Count</strong>
                    memberships shown
                </span>
            </div>

            <section class="report-source-section" aria-labelledby="low-remaining-results-title">
                <header class="report-section-header">
                    <div>
                        <p class="eyebrow">Canonical Memberships state</p>
                        <h2 id="low-remaining-results-title">Low remaining visits</h2>
                    </div>
                </header>

                @if (reportPage.Items.Count == 0)
                {
                    <p class="empty-state">No active memberships are at or below this threshold.</p>
                }
                else
                {
                    <ol class="report-row-list" data-low-remaining-rows>
                        @foreach (var row in reportPage.Items)
                        {
                            <li class="report-row low-remaining-row"
                                data-client-id="@row.ClientId"
                                data-membership-id="@row.MembershipId"
                                data-counted-visits="@row.CountedVisits"
                                data-remaining-visits="@row.RemainingVisits"
                                data-visits-limit="@row.VisitsLimitSnapshot">
                                <header class="report-row-header">
                                    <div>
                                        <p class="report-row-kind">@row.MembershipTypeName</p>
                                        <h3>@row.ClientDisplayName</h3>
                                    </div>
                                    <div class="report-membership-heading">
                                        <strong>@RemainingVisitsLabel(row.RemainingVisits)</strong>
                                        <span class="status-chip @StatusChipClass(row.RemainingVisits)">
                                            @StatusLabel(row.RemainingVisits)
                                        </span>
                                    </div>
                                </header>

                                <dl class="report-row-meta report-membership-meta">
                                    <div>
                                        <dt>Phone</dt>
                                        <dd>@(row.ClientPhone ?? "No phone")</dd>
                                    </div>
                                    <div>
                                        <dt>Visit limit</dt>
                                        <dd>@row.VisitsLimitSnapshot</dd>
                                    </div>
                                    <div>
                                        <dt>Counted visits</dt>
                                        <dd>@row.CountedVisits</dd>
                                    </div>
                                    <div>
                                        <dt>Remaining visits</dt>
                                        <dd>@row.RemainingVisits</dd>
                                    </div>
                                    <div>
                                        <dt>Last counted visit</dt>
                                        <dd>@FormatLastVisit(row.LastCountedVisitAt)</dd>
                                    </div>
                                    <div>
                                        <dt>Effective end</dt>
                                        <dd>@row.EffectiveEndDate.ToString("yyyy-MM-dd")</dd>
                                    </div>
                                </dl>

                                @if (row.Warnings.Count > 0)
                                {
                                    <ul class="warning-chip-list report-warning-list"
                                        aria-label="Membership warnings">
                                        @foreach (var warning in row.Warnings)
                                        {
                                            <li class="@WarningClass(warning.Severity)"
                                                data-membership-warning="@warning.Code">
                                                @warning.Message
                                            </li>
                                        }
                                    </ul>
                                }

                                <footer class="report-row-actions">
                                    <a class="secondary-link"
                                       asp-page="/Reception/Index"
                                       asp-route-clientId="@row.ClientId"
                                       asp-fragment="membership-panel-title">
                                        Open client
                                    </a>
                                    @if (row.HasExtensionExplanation)
                                    {
                                        <a class="secondary-link"
                                           asp-page="/Reception/Index"
                                           asp-route-clientId="@row.ClientId"
                                           asp-fragment="membership-extension-history-title">
                                            Extension details
                                        </a>
                                    }
                                </footer>
                            </li>
                        }
                    </ol>
                }

                @if (Model.PreviousOffset is not null || reportPage.NextOffset is not null)
                {
                    <nav class="report-pagination" aria-label="Low-remaining result pages">
                        <span class="report-pagination-slot">
                            @if (Model.PreviousOffset is { } previousOffset)
                            {
                                <a class="secondary-link"
                                   asp-page="/Reports/LowRemaining"
                                   asp-route-asOf="@reportPage.AsOfDate.ToString("yyyy-MM-dd")"
                                   asp-route-remaining="@reportPage.RemainingVisitsThreshold"
                                   asp-route-offset="@previousOffset">
                                    Previous
                                </a>
                            }
                        </span>
                        <span class="result-count">Page @Model.CurrentPageNumber</span>
                        <span class="report-pagination-slot report-pagination-next">
                            @if (reportPage.NextOffset is { } nextOffset)
                            {
                                <a class="secondary-link"
                                   asp-page="/Reports/LowRemaining"
                                   asp-route-asOf="@reportPage.AsOfDate.ToString("yyyy-MM-dd")"
                                   asp-route-remaining="@reportPage.RemainingVisitsThreshold"
                                   asp-route-offset="@nextOffset">
                                    Next
                                </a>
                            }
                        </span>
                    </nav>
                }
            </section>
        }
    </section>
</main>

@functions {
    private static string RemainingVisitsLabel(int remainingVisits)
    {
        return remainingVisits switch
        {
            1 => "1 visit left",
            _ => $"{remainingVisits} visits left",
        };
    }

    private static string StatusLabel(int remainingVisits)
    {
        return remainingVisits switch
        {
            < 0 => "Negative",
            0 => "No visits",
            _ => "Low remaining",
        };
    }

    private static string StatusChipClass(int remainingVisits)
    {
        return remainingVisits <= 0
            ? "status-canceled"
            : "status-corrected";
    }

    private static string FormatLastVisit(DateTimeOffset? lastCountedVisitAt)
    {
        return lastCountedVisitAt is { } timestamp
            ? $"{timestamp.ToUniversalTime():yyyy-MM-dd HH:mm} UTC"
            : "No counted visits";
    }

    private static string WarningClass(MembershipWarningSeverity severity)
    {
        return severity == MembershipWarningSeverity.Danger
            ? "warning-chip-danger"
            : "warning-chip-caution";
    }
}
