@page
@model BodyLife.Crm.Web.Pages.Reports.DailyModel
@using BodyLife.Crm.Web.Localization
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<BodyLife.Crm.Web.Localization.Reports> L
@{
    ViewData["Title"] = L["Daily.Title"];
    var report = Model.Report;
    var errorMessage = Model.LoadError;
}

<main class="page-shell report-page" data-daily-report-page>
    <section class="report-layout" aria-labelledby="daily-report-title">
        <header class="report-header">
            <div>
                <p class="eyebrow">@L["Navigation.Reports"]</p><h1 id="daily-report-title">@L["Daily.Title"]</h1>
            </div>
            <nav class="report-header-actions" aria-label="@L["Navigation"]">
                <a class="secondary-link" asp-page="/Reports/EndingSoon">@L["Ending"]</a><a class="secondary-link" asp-page="/Reports/LowRemaining">@L["Low"]</a><a class="secondary-link" asp-page="/Reports/NegativeClients">@L["Negative"]</a><a class="secondary-link" asp-page="/Reports/InactiveClients">@L["Inactive"]</a><a class="secondary-link" asp-page="/Reception/Index">@L["Navigation.Reception"]</a>
            </nav>
        </header>

        <form class="report-filter"
              method="get"
              asp-page="/Reports/Daily"
              data-busy-form>
            <div class="report-date-field">
                <label for="business-date">@L["BusinessDate"]</label>
                <input id="business-date"
                       name="date"
                       type="date"
                       value="@Model.BusinessDate?.ToString("yyyy-MM-dd")"
                       required />
            </div>
            <button type="submit" data-busy-text="@L["Loading"]">@L["Load"]</button>
        </form>

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="warning-block warning-danger report-error" role="alert">
                <strong>@L["Unavailable"]</strong>
                <span>@errorMessage</span>
            </div>
        }
        else if (report is not null)
        {
            <section class="report-summary" aria-label="@L["Daily.Totals"]">
                <div>
                    <span class="report-summary-label">@L["CountedVisits"]</span>
                    <strong data-report-visit-count>@report.VisitCount</strong>
                </div>
                <div>
                    <span class="report-summary-label">@L["Payment"]</span>
                    <strong data-report-payment-count>@report.PaymentCount</strong>
                </div>
                <div>
                    <span class="report-summary-label">@L["Payment.Cash"]</span>
                    <strong data-report-cash-sum>@MoneyLabel(report.DailyCashSum)</strong>
                </div>
                <div>
                    <span class="report-summary-label">@L["DayStatus"]</span>
                    <strong>
                        <span class="status-chip @DayStatusClass(report.DayStatus)"
                              data-report-day-status="@report.DayStatus.ToString().ToLowerInvariant()">
                            @DayStatusLabel(report.DayStatus)
                        </span>
                    </strong>
                </div>
            </section>

            <div class="report-source-note">
                <strong>@ReportsPresentation.Date(report.BusinessDate)</strong><span>@L["Daily.Note"]</span>
            </div>

            <section class="report-source-section" aria-labelledby="daily-visits-title">
                <header class="report-section-header">
                    <div>
                        <p class="eyebrow">@L["VisitFacts"]</p><h2 id="daily-visits-title">@L["Visit.Label"]</h2>
                    </div>
                </header>

                @if (report.VisitRows.Count == 0)
                {
                    <p class="empty-state">@L["Daily.EmptyVisits"]</p>
                }
                else
                {
                    <ol class="report-row-list" data-report-visit-rows>
                        @foreach (var sourceRow in report.VisitRows)
                        {
                            var visit = sourceRow.Visit;
                            <li class="report-row"
                                data-report-visit-id="@visit.VisitId"
                                data-report-row-status="@visit.Status.ToString().ToLowerInvariant()">
                                <header class="report-row-header">
                                    <div>
                                        <p class="report-row-kind">@VisitKindLabel(visit.VisitKind)</p>
                                        <h3>@sourceRow.ClientDisplayName</h3>
                                    </div>
                                    <span class="status-chip @(visit.Status == ClientVisitRowStatus.Active ? "status-active" : "status-canceled")">
                                        @(visit.Status == ClientVisitRowStatus.Active
                                            ? L["Status.Active"]
                                            : L["Status.Canceled"])
                                    </span>
                                </header>

                                <dl class="report-row-meta">
                                    <div>
                                        <dt>@L["Meta.Occurred"]</dt>
                                        <dd>@UtcTimestamp(visit.OccurredAt)</dd>
                                    </div>
                                    <div>
                                        <dt>@L["Meta.Recorded"]</dt>
                                        <dd>@UtcTimestamp(visit.RecordedAt)</dd>
                                    </div>
                                    @if (visit.Consumption is { } consumption)
                                    {
                                        <div>
                                            <dt>@L["Entity.Membership"]</dt>
                                            <dd>@consumption.MembershipTypeNameSnapshot</dd>
                                        </div>
                                    }
                                    @if (visit.EntryOrigin != EntryOrigin.Normal)
                                    {
                                        <div>
                                            <dt>@L["Meta.Source"]</dt>
                                            <dd><span class="source-label">@EntryOriginLabel(visit.EntryOrigin)</span></dd>
                                        </div>
                                    }
                                </dl>

                                @if (!string.IsNullOrWhiteSpace(visit.Comment))
                                {
                                    <p class="report-row-comment">@visit.Comment</p>
                                }

                                @if (visit.Cancellation is { } cancellation)
                                {
                                    <div class="report-row-event report-row-cancellation" data-report-cancellation>
                                        <strong>@L["Status.Cancellation"]</strong>
                                        <span>@cancellation.Reason</span>
                                        <span>@UtcTimestamp(cancellation.RecordedAt)</span>
                                        @if (cancellation.EntryOrigin != EntryOrigin.Normal)
                                        {
                                            <span class="source-label">@EntryOriginLabel(cancellation.EntryOrigin)</span>
                                        }
                                    </div>
                                }

                                <footer class="report-row-actions">
                                    <a class="secondary-link"
                                       asp-page="/Reception/Index"
                                       asp-route-clientId="@visit.ClientId"
                                       asp-fragment="recent-visits-title"
                                       data-report-client-link>
                                        Open client
                                    </a>
                                    <a class="secondary-link"
                                       asp-page="/Audit/ClientHistory"
                                       asp-route-clientId="@visit.ClientId"
                                       asp-route-entity="@ClientHistoryEntityFilter.Visit"
                                       asp-route-from="@report.BusinessDate.ToString("yyyy-MM-dd")"
                                       asp-route-to="@report.BusinessDate.ToString("yyyy-MM-dd")"
                                       data-report-history-link>
                                        Client history
                                    </a>
                                    <a class="secondary-link"
                                       asp-page="/Audit/Timeline"
                                       asp-route-clientId="@visit.ClientId"
                                       asp-route-entity="@AuditTimelineEntityType.Visit"
                                       asp-route-entityId="@visit.VisitId"
                                       data-report-audit-link>
                                        Audit timeline
                                    </a>
                                </footer>
                            </li>
                        }
                    </ol>
                }
            </section>

            <section class="report-source-section" aria-labelledby="daily-payments-title">
                <header class="report-section-header">
                    <div>
                        <p class="eyebrow">@L["PaymentFacts"]</p><h2 id="daily-payments-title">@L["Payment"]</h2>
                    </div>
                </header>

                @if (report.PaymentRows.Count == 0)
                {
                    <p class="empty-state">@L["Daily.EmptyPayments"]</p>
                }
                else
                {
                    <ol class="report-row-list" data-report-payment-rows>
                        @foreach (var sourceRow in report.PaymentRows)
                        {
                            var payment = sourceRow.Payment;
                            var paymentKey = payment.PaymentId.ToString("N");
                            var paymentAuditEntityId =
                                payment.CorrectionFromOriginal?.OriginalPaymentId
                                ?? payment.PaymentId;
                            <li class="report-row"
                                data-report-payment-id="@payment.PaymentId"
                                data-report-row-status="@payment.Status.ToString().ToLowerInvariant()">
                                <header class="report-row-header">
                                    <div>
                                        <p class="report-row-kind">@PaymentContextLabel(payment.PaymentContext)</p>
                                        <h3>@sourceRow.ClientDisplayName</h3>
                                    </div>
                                    <div class="report-payment-heading">
                                        <strong>@MoneyLabel(payment.Amount)</strong>
                                        <span class="status-chip @PaymentStatusClass(payment.Status)">
                                            @PaymentStatusLabel(payment.Status)
                                        </span>
                                    </div>
                                </header>

                                <dl class="report-row-meta">
                                    <div>
                                        <dt>@L["Meta.Occurred"]</dt>
                                        <dd>@UtcTimestamp(payment.OccurredAt)</dd>
                                    </div>
                                    <div>
                                        <dt>@L["Meta.Recorded"]</dt>
                                        <dd>@UtcTimestamp(payment.RecordedAt)</dd>
                                    </div>
                                    <div>
                                        <dt>@L["Payment.Method"]</dt>
                                        <dd>@PaymentMethodLabel(payment.Method)</dd>
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(payment.MembershipTypeNameSnapshot))
                                    {
                                        <div>
                                            <dt>@L["Entity.Membership"]</dt>
                                            <dd>@payment.MembershipTypeNameSnapshot</dd>
                                        </div>
                                    }
                                    @if (payment.EntryOrigin != EntryOrigin.Normal)
                                    {
                                        <div>
                                            <dt>@L["Meta.Source"]</dt>
                                            <dd><span class="source-label">@EntryOriginLabel(payment.EntryOrigin)</span></dd>
                                        </div>
                                    }
                                </dl>

                                @if (!string.IsNullOrWhiteSpace(payment.Comment))
                                {
                                    <p class="report-row-comment">@payment.Comment</p>
                                }

                                @if (payment.Cancellation is { } cancellation)
                                {
                                    <div class="report-row-event report-row-cancellation" data-report-cancellation>
                                        <strong>@L["Status.Cancellation"]</strong>
                                        <span>@cancellation.Reason</span>
                                        <span>@UtcTimestamp(cancellation.RecordedAt)</span>
                                        @if (cancellation.EntryOrigin != EntryOrigin.Normal)
                                        {
                                            <span class="source-label">@EntryOriginLabel(cancellation.EntryOrigin)</span>
                                        }
                                    </div>
                                }

                                @if (payment.CorrectionFromOriginal is { } correctionFromOriginal)
                                {
                                    <div class="report-row-event report-row-correction" data-report-correction>
                                        <strong>@L["CorrectedReplacement"]</strong>
                                        <span>@correctionFromOriginal.Reason</span>
                                        <span>@L["Status.Changed"]: @ChangedFieldsLabel(correctionFromOriginal.ChangedFields)</span>
                                        <span>@UtcTimestamp(correctionFromOriginal.RecordedAt)</span>
                                        @if (correctionFromOriginal.EntryOrigin != EntryOrigin.Normal)
                                        {
                                            <span class="source-label">@EntryOriginLabel(correctionFromOriginal.EntryOrigin)</span>
                                        }
                                    </div>
                                }
                                else if (payment.CorrectionToReplacement is { } correctionToReplacement)
                                {
                                    <div class="report-row-event report-row-correction" data-report-correction>
                                        <strong>@L["ReplacedPayment"]</strong>
                                        <span>@correctionToReplacement.Reason</span>
                                        <span>@L["Status.Changed"]: @ChangedFieldsLabel(correctionToReplacement.ChangedFields)</span>
                                        <span>@UtcTimestamp(correctionToReplacement.RecordedAt)</span>
                                        @if (correctionToReplacement.EntryOrigin != EntryOrigin.Normal)
                                        {
                                            <span class="source-label">@EntryOriginLabel(correctionToReplacement.EntryOrigin)</span>
                                        }
                                    </div>
                                }

                                <footer class="report-row-actions">
                                    @if (payment.Status == ClientPaymentRowStatus.Active
                                        && payment.AllowedActions.IsAllowed(PaymentActionKeys.Correct))
                                    {
                                        <a class="secondary-link"
                                           asp-page="/Reception/Index"
                                           asp-route-clientId="@payment.ClientId"
                                           asp-route-correctPaymentId="@payment.PaymentId"
                                           asp-fragment="correct-payment-panel-@paymentKey"
                                           data-report-correct-payment>
                                            @L["CorrectPayment"]
                                        </a>
                                    }
                                    <a class="secondary-link"
                                       asp-page="/Reception/Index"
                                       asp-route-clientId="@payment.ClientId"
                                       asp-fragment="recent-payments-title"
                                       data-report-client-link>
                                        @L["OpenClient"]
                                    </a>
                                    <a class="secondary-link"
                                       asp-page="/Audit/ClientHistory"
                                       asp-route-clientId="@payment.ClientId"
                                       asp-route-entity="@ClientHistoryEntityFilter.Payment"
                                       asp-route-from="@report.BusinessDate.ToString("yyyy-MM-dd")"
                                       asp-route-to="@report.BusinessDate.ToString("yyyy-MM-dd")"
                                       data-report-history-link>
                                        @L["ClientHistory"]
                                    </a>
                                    <a class="secondary-link"
                                       asp-page="/Audit/Timeline"
                                       asp-route-clientId="@payment.ClientId"
                                       asp-route-entity="@AuditTimelineEntityType.Payment"
                                       asp-route-entityId="@paymentAuditEntityId"
                                       data-report-audit-link>
                                        @L["AuditTimeline"]
                                    </a>
                                </footer>
                            </li>
                        }
                    </ol>
                }
            </section>
        }
    </section>
</main>

@functions {
    private static string MoneyLabel(Money money)
    {
        return ReportsPresentation.Money(money);
    }

    private static string UtcTimestamp(DateTimeOffset timestamp)
    {
        return ReportsPresentation.Timestamp(timestamp);
    }

    private static string DayStatusClass(DailyReportDayStatus status)
    {
        return status == DailyReportDayStatus.Open
            ? "status-active"
            : "status-corrected";
    }

    private string DayStatusLabel(DailyReportDayStatus status)
    {
        return status == DailyReportDayStatus.Open
            ? L["Status.Open"] : L["Status.Reconciled"];
    }

    private string VisitKindLabel(VisitKind visitKind)
    {
        return visitKind switch
        {
            VisitKind.Membership => L["VisitKind.Membership"], VisitKind.OneOff => L["VisitKind.OneOff"], VisitKind.Trial => L["VisitKind.Trial"], _ => L["Visit.Label"],
        };
    }

    private string EntryOriginLabel(EntryOrigin entryOrigin)
    {
        return entryOrigin switch
        {
            EntryOrigin.Normal => L["Origin.Normal"], EntryOrigin.ManualBackfill => L["Origin.Backfill"], EntryOrigin.PaperFallback => L["Origin.Paper"], EntryOrigin.FutureImport => L["Origin.Import"], _ => L["Origin.Unknown"],
        };
    }

    private string PaymentMethodLabel(PaymentMethod method)
    {
        return method == PaymentMethod.Cash ? L["Payment.Cash"] : L["UnknownMethod"];
    }

    private string PaymentContextLabel(PaymentContext paymentContext)
    {
        return paymentContext switch
        {
            PaymentContext.MembershipSale => L["Context.Sale"], PaymentContext.OneOff => L["Context.OneOff"], PaymentContext.Trial => L["Context.Trial"], PaymentContext.NegativeClosure => L["Context.NegativeClosure"], PaymentContext.Other => L["Context.Other"], _ => L["Payment"],
        };
    }

    private static string PaymentStatusClass(ClientPaymentRowStatus status)
    {
        return status switch
        {
            ClientPaymentRowStatus.Active => "status-active",
            ClientPaymentRowStatus.Canceled => "status-canceled",
            ClientPaymentRowStatus.Replaced => "status-replaced",
            _ => "status-inactive",
        };
    }

    private string PaymentStatusLabel(ClientPaymentRowStatus status)
    {
        return status switch
        {
            ClientPaymentRowStatus.Active => L["Status.Active"], ClientPaymentRowStatus.Canceled => L["Status.Canceled"], ClientPaymentRowStatus.Replaced => L["Status.Replaced"], _ => L["Value.Unknown"],
        };
    }

    private string ChangedFieldsLabel(IReadOnlyList<string> changedFields)
    {
        return string.Join(", ", changedFields.Select(ChangedFieldLabel));
    }

    private string ChangedFieldLabel(string changedField)
    {
        return changedField switch
        {
            "amount" => L["Field.Amount"], "occurred_at" => L["Field.Occurred"], "payment_context" => L["Field.Context"], "membership_id" => L["Field.Membership"], "comment" => L["Field.Comment"], _ => L["Field.Other"],
        };
    }
}
