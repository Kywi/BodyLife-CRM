@page
@model BodyLife.Crm.Web.Pages.Owner.MembershipTypesModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<BodyLife.Crm.Web.Localization.Shared> SharedLocalizer
@{
    ViewData["Title"] = Model.T("MembershipTypes.Title");
}

<main class="page-shell">
    <section class="owner-management" aria-labelledby="membership-types-title">
        <header class="management-header">
            <div>
                <p class="eyebrow">@Model.T("MembershipTypes.OwnerSettings")</p>
                <h1 id="membership-types-title">@Model.T("MembershipTypes.Title")</h1>
            </div>
            <a class="secondary-link" asp-page="/Reception/Index">@Model.T("MembershipTypes.Reception")</a>
        </header>

        @if (!string.IsNullOrWhiteSpace(Model.OperationMessage))
        {
            <div class="operation-message operation-success" role="status">
                @Model.OperationMessage
            </div>
        }

        @if (Model.CanCreateCatalog)
        {
            var createInput = Model.CreateForm.Input;

            <section class="catalog-create-section" aria-labelledby="create-membership-type-title">
                <header class="catalog-create-header">
                    <h2 id="create-membership-type-title">@Model.T("MembershipTypes.Add")</h2>
                    <span class="status-chip status-owner">@Model.T("MembershipTypes.OwnerOnly")</span>
                </header>

                @if (Model.CreateForm.Errors.Count > 0)
                {
                    <div class="command-error-summary" role="alert">
                        <strong>@Model.T("MembershipTypes.CreateFailed")</strong>
                        <ul>
                            @foreach (var message in Model.CreateForm.Errors.Select(Model.DisplayError).Distinct(StringComparer.Ordinal))
                            {
                                <li>@message</li>
                            }
                        </ul>
                    </div>
                }

                <form id="create-membership-type-form"
                      class="membership-type-create-form"
                      method="post"
                      asp-page="/Owner/MembershipTypes"
                      asp-page-handler="Create"
                      data-busy-form>
                    <input type="hidden" name="form.IdempotencyKey" value="@createInput.IdempotencyKey" />

                    <div class="membership-type-create-grid">
                        <div class="form-field form-field-span-2">
                            <label for="membership-type-name">@Model.T("MembershipTypes.Name")</label>
                            <input id="membership-type-name"
                                   name="form.Name"
                                   type="text"
                                   value="@createInput.Name"
                                   required
                                   autocomplete="off" />
                        </div>
                        <div class="form-field">
                            <label for="membership-type-duration">@Model.T("MembershipTypes.Duration")</label>
                            <input id="membership-type-duration"
                                   name="form.DurationDays"
                                   type="number"
                                   value="@createInput.DurationDays"
                                   min="1"
                                   step="1"
                                   required />
                        </div>
                        <div class="form-field">
                            <label for="membership-type-visits">@Model.T("MembershipTypes.VisitLimit")</label>
                            <input id="membership-type-visits"
                                   name="form.VisitsLimit"
                                   type="number"
                                   value="@createInput.VisitsLimit"
                                   min="0"
                                   step="1"
                                   required />
                        </div>
                        <div class="form-field">
                            <label for="membership-type-price">@Model.T("MembershipTypes.PriceAmount")</label>
                            <input id="membership-type-price"
                                   name="form.PriceAmount"
                                   type="number"
                                   value="@MembershipTypesModel.FormatPriceInput(createInput.PriceAmount)"
                                   min="0"
                                   step="0.01"
                                   required />
                        </div>
                        <div class="form-field">
                            <label for="membership-type-currency">@Model.T("MembershipTypes.Currency")</label>
                            <input id="membership-type-currency"
                                   name="form.PriceCurrency"
                                   type="text"
                                   value="@createInput.PriceCurrency"
                                   maxlength="12"
                                   required
                                   autocomplete="off" />
                        </div>
                        <div class="form-field form-field-span-2">
                            <label for="membership-type-comment">@Model.T("MembershipTypes.Comment")</label>
                            <textarea id="membership-type-comment"
                                      name="form.Comment"
                                      rows="3">@createInput.Comment</textarea>
                        </div>
                        <div class="catalog-create-actions">
                            <button type="submit" data-busy-text="@Model.T("MembershipTypes.Adding")">@Model.T("MembershipTypes.Add")</button>
                        </div>
                    </div>
                </form>
            </section>
        }

        <section class="membership-type-list" aria-labelledby="membership-type-list-title">
            <header class="list-header">
                <div>
                    <h2 id="membership-type-list-title">@Model.T("MembershipTypes.Catalog")</h2>
                    <p class="list-breakdown">
                        <span>@Model.T("MembershipTypes.ActiveCount", Model.ActiveCount)</span>
                        <span>@Model.T("MembershipTypes.InactiveCount", Model.InactiveCount)</span>
                    </p>
                </div>
                <div class="catalog-list-summary">
                    @if (Model.CanManageCatalog)
                    {
                        <span class="status-chip status-owner">@Model.T("MembershipTypes.OwnerManaged")</span>
                    }
                    <span class="list-count">
                        @Model.T("MembershipTypes.TypeCount", Model.MembershipTypes.Count)
                    </span>
                </div>
            </header>

            @if (Model.CatalogErrors.Count > 0)
            {
                <div class="command-error-summary" role="alert">
                    <strong>@Model.T("MembershipTypes.CatalogFailed")</strong>
                    <ul>
                        @foreach (var message in Model.CatalogErrors.Select(Model.DisplayError).Distinct(StringComparer.Ordinal))
                        {
                            <li>@message</li>
                        }
                    </ul>
                </div>
            }

            @if (Model.MembershipTypes.Count == 0)
            {
                <p class="empty-state">@Model.T("MembershipTypes.Empty")</p>
            }
            else
            {
                @foreach (var membershipType in Model.MembershipTypes)
                {
                    var membershipTypeKey = membershipType.MembershipTypeId.ToString("N");

                    <article id="membership-type-@membershipTypeKey"
                             class="membership-type-row"
                             data-membership-type-id="@membershipType.MembershipTypeId"
                             data-membership-type-status="@(membershipType.IsActive ? "active" : "inactive")">
                        <header class="membership-type-header">
                            <h3>@membershipType.Name</h3>
                            <span class="status-chip @(membershipType.IsActive ? "status-active" : "status-inactive")">
                                @(membershipType.IsActive ? Model.T("MembershipTypes.Active") : Model.T("MembershipTypes.Inactive"))
                            </span>
                        </header>

                        <dl class="membership-type-meta">
                            <div>
                                <dt>@Model.T("MembershipTypes.Duration")</dt>
                                <dd>@WebPluralizer.Days(SharedLocalizer, membershipType.DurationDays)</dd>
                            </div>
                            <div>
                                <dt>@Model.T("MembershipTypes.VisitLimit")</dt>
                                <dd>@membershipType.VisitsLimit</dd>
                            </div>
                            <div>
                                <dt>@Model.T("MembershipTypes.Price")</dt>
                                <dd>@MembershipTypesModel.FormatPrice(membershipType.Price)</dd>
                            </div>
                            <div>
                                <dt>@Model.T("MembershipTypes.Created")</dt>
                                <dd>@MembershipTypesModel.FormatTimestamp(membershipType.CreatedAt)</dd>
                            </div>
                            <div>
                                <dt>@Model.T("MembershipTypes.Updated")</dt>
                                <dd>@MembershipTypesModel.FormatTimestamp(membershipType.UpdatedAt)</dd>
                            </div>
                            <div>
                                <dt>@Model.T("MembershipTypes.Deactivated")</dt>
                                <dd>
                                    @(membershipType.DeactivatedAt is { } deactivatedAt
                                        ? MembershipTypesModel.FormatTimestamp(deactivatedAt)
                                        : Model.T("MembershipTypes.NotDeactivated"))
                                </dd>
                            </div>
                            <div class="membership-type-comment">
                                <dt>@Model.T("MembershipTypes.Comment")</dt>
                                <dd>@(membershipType.Comment ?? Model.T("MembershipTypes.NoComment"))</dd>
                            </div>
                        </dl>

                        @if (Model.CanEditCatalog
                            && Model.EditForms.TryGetValue(membershipType.MembershipTypeId, out var editForm))
                        {
                            var editInput = editForm.Input;

                            <details class="membership-type-edit-panel" open="@(editForm.IsOpen ? "open" : null)">
                                <summary>@Model.T("MembershipTypes.EditValues")</summary>
                                <div class="membership-type-edit-content">
                                    @if (editForm.Errors.Count > 0)
                                    {
                                        <div class="command-error-summary" role="alert">
                                            <strong>@Model.T("MembershipTypes.UpdateFailed")</strong>
                                            <ul>
                                                @foreach (var message in editForm.Errors.Select(Model.DisplayError).Distinct(StringComparer.Ordinal))
                                                {
                                                    <li>@message</li>
                                                }
                                            </ul>
                                        </div>
                                    }

                                    <form id="edit-membership-type-form-@membershipTypeKey"
                                          class="membership-type-edit-form"
                                          method="post"
                                          asp-page="/Owner/MembershipTypes"
                                          asp-page-handler="Edit"
                                          data-busy-form>
                                        <input type="hidden" name="form.MembershipTypeId" value="@editInput.MembershipTypeId" />
                                        <input type="hidden" name="form.ExpectedUpdatedAt" value="@editInput.ExpectedUpdatedAt.ToString("O")" />
                                        <input type="hidden" name="form.IdempotencyKey" value="@editInput.IdempotencyKey" />

                                        <div class="membership-type-edit-grid">
                                            <div class="form-field form-field-span-2">
                                                <label for="edit-membership-type-name-@membershipTypeKey">@Model.T("MembershipTypes.Name")</label>
                                                <input id="edit-membership-type-name-@membershipTypeKey"
                                                       name="form.Name"
                                                       type="text"
                                                       value="@editInput.Name"
                                                       required
                                                       autocomplete="off" />
                                            </div>
                                            <div class="form-field">
                                                <label for="edit-membership-type-duration-@membershipTypeKey">@Model.T("MembershipTypes.Duration")</label>
                                                <input id="edit-membership-type-duration-@membershipTypeKey"
                                                       name="form.DurationDays"
                                                       type="number"
                                                       value="@editInput.DurationDays"
                                                       min="1"
                                                       step="1"
                                                       required />
                                            </div>
                                            <div class="form-field">
                                                <label for="edit-membership-type-visits-@membershipTypeKey">@Model.T("MembershipTypes.VisitLimit")</label>
                                                <input id="edit-membership-type-visits-@membershipTypeKey"
                                                       name="form.VisitsLimit"
                                                       type="number"
                                                       value="@editInput.VisitsLimit"
                                                       min="0"
                                                       step="1"
                                                       required />
                                            </div>
                                            <div class="form-field">
                                                <label for="edit-membership-type-price-@membershipTypeKey">@Model.T("MembershipTypes.PriceAmount")</label>
                                                <input id="edit-membership-type-price-@membershipTypeKey"
                                                       name="form.PriceAmount"
                                                       type="number"
                                                       value="@MembershipTypesModel.FormatPriceInput(editInput.PriceAmount)"
                                                       min="0"
                                                       step="0.01"
                                                       required />
                                            </div>
                                            <div class="form-field">
                                                <label for="edit-membership-type-currency-@membershipTypeKey">@Model.T("MembershipTypes.Currency")</label>
                                                <input id="edit-membership-type-currency-@membershipTypeKey"
                                                       name="form.PriceCurrency"
                                                       type="text"
                                                       value="@editInput.PriceCurrency"
                                                       maxlength="12"
                                                       required
                                                       autocomplete="off" />
                                            </div>
                                            <div class="form-field form-field-span-2">
                                                <label for="edit-membership-type-comment-@membershipTypeKey">@Model.T("MembershipTypes.CatalogComment")</label>
                                                <textarea id="edit-membership-type-comment-@membershipTypeKey"
                                                          name="form.Comment"
                                                          rows="2">@editInput.Comment</textarea>
                                            </div>
                                            <div class="form-field form-field-span-full">
                                                <label for="edit-membership-type-reason-@membershipTypeKey">@Model.T("MembershipTypes.ChangeReason")</label>
                                                <textarea id="edit-membership-type-reason-@membershipTypeKey"
                                                          name="form.Reason"
                                                          rows="2"
                                                          maxlength="1000"
                                                          required>@editInput.Reason</textarea>
                                            </div>
                                            <div class="catalog-edit-actions">
                                                <button class="secondary-button"
                                                        type="submit"
                                                        data-busy-text="@Model.T("MembershipTypes.Saving")">@Model.T("MembershipTypes.Save")</button>
                                            </div>
                                        </div>
                                    </form>
                                </div>
                            </details>
                        }

                        @if (Model.CanDeactivateCatalog
                            && membershipType.IsActive
                            && Model.DeactivateForms.TryGetValue(
                                membershipType.MembershipTypeId,
                                out var deactivateForm))
                        {
                            var deactivateInput = deactivateForm.Input;

                            <details class="membership-type-deactivate-panel"
                                     open="@(deactivateForm.IsOpen ? "open" : null)">
                                <summary>@Model.T("MembershipTypes.Deactivate")</summary>
                                <div class="membership-type-deactivate-content">
                                    @if (deactivateForm.Errors.Count > 0)
                                    {
                                        <div class="command-error-summary" role="alert">
                                            <strong>@Model.T("MembershipTypes.DeactivateFailed")</strong>
                                            <ul>
                                                @foreach (var message in deactivateForm.Errors.Select(Model.DisplayError).Distinct(StringComparer.Ordinal))
                                                {
                                                    <li>@message</li>
                                                }
                                            </ul>
                                        </div>
                                    }

                                    <form id="deactivate-membership-type-form-@membershipTypeKey"
                                          class="membership-type-deactivate-form"
                                          method="post"
                                          asp-page="/Owner/MembershipTypes"
                                          asp-page-handler="Deactivate"
                                          data-busy-form
                                          data-confirm="@Model.T("MembershipTypes.DeactivateConfirm")">
                                        <input type="hidden" name="form.MembershipTypeId" value="@deactivateInput.MembershipTypeId" />
                                        <input type="hidden" name="form.ExpectedUpdatedAt" value="@deactivateInput.ExpectedUpdatedAt.ToString("O")" />
                                        <input type="hidden" name="form.IdempotencyKey" value="@deactivateInput.IdempotencyKey" />

                                        <div class="membership-type-deactivate-grid">
                                            <div class="form-field">
                                                <label for="deactivate-membership-type-reason-@membershipTypeKey">@Model.T("MembershipTypes.DeactivateReason")</label>
                                                <textarea id="deactivate-membership-type-reason-@membershipTypeKey"
                                                          name="form.Reason"
                                                          rows="2"
                                                          maxlength="1000"
                                                          required>@deactivateInput.Reason</textarea>
                                            </div>
                                            <button class="danger-button"
                                                    type="submit"
                                                    data-busy-text="@Model.T("MembershipTypes.Deactivating")">@Model.T("MembershipTypes.Deactivate")</button>
                                        </div>
                                    </form>
                                </div>
                            </details>
                        }
                    </article>
                }
            }
        </section>
    </section>
</main>
