@page
@model BodyLife.Crm.Web.Pages.Owner.MembershipTypesModel
@{
    ViewData["Title"] = "Membership types";
}

<main class="page-shell">
    <section class="owner-management" aria-labelledby="membership-types-title">
        <header class="management-header">
            <div>
                <p class="eyebrow">Owner settings</p>
                <h1 id="membership-types-title">Membership types</h1>
            </div>
            <a class="secondary-link" asp-page="/Reception/Index">Reception</a>
        </header>

        @if (!string.IsNullOrWhiteSpace(Model.OperationMessage))
        {
            <div class="operation-message operation-success" role="status">
                @Model.OperationMessage
            </div>
        }

        @if (Model.CanCreateCatalog)
        {
            var createInput = Model.CreateForm.Input;

            <section class="catalog-create-section" aria-labelledby="create-membership-type-title">
                <header class="catalog-create-header">
                    <h2 id="create-membership-type-title">Add membership type</h2>
                    <span class="status-chip status-owner">Owner only</span>
                </header>

                @if (Model.CreateForm.Errors.Count > 0)
                {
                    <div class="command-error-summary" role="alert">
                        <strong>Membership type not created</strong>
                        <ul>
                            @foreach (var message in Model.CreateForm.Errors.Select(DisplayCreateError).Distinct(StringComparer.Ordinal))
                            {
                                <li>@message</li>
                            }
                        </ul>
                    </div>
                }

                <form id="create-membership-type-form"
                      class="membership-type-create-form"
                      method="post"
                      asp-page="/Owner/MembershipTypes"
                      asp-page-handler="Create"
                      data-busy-form>
                    <input type="hidden" name="form.IdempotencyKey" value="@createInput.IdempotencyKey" />

                    <div class="membership-type-create-grid">
                        <div class="form-field form-field-span-2">
                            <label for="membership-type-name">Name</label>
                            <input id="membership-type-name"
                                   name="form.Name"
                                   type="text"
                                   value="@createInput.Name"
                                   required
                                   autocomplete="off" />
                        </div>
                        <div class="form-field">
                            <label for="membership-type-duration">Duration (days)</label>
                            <input id="membership-type-duration"
                                   name="form.DurationDays"
                                   type="number"
                                   value="@createInput.DurationDays"
                                   min="1"
                                   step="1"
                                   required />
                        </div>
                        <div class="form-field">
                            <label for="membership-type-visits">Visit limit</label>
                            <input id="membership-type-visits"
                                   name="form.VisitsLimit"
                                   type="number"
                                   value="@createInput.VisitsLimit"
                                   min="0"
                                   step="1"
                                   required />
                        </div>
                        <div class="form-field">
                            <label for="membership-type-price">Price amount</label>
                            <input id="membership-type-price"
                                   name="form.PriceAmount"
                                   type="number"
                                   value="@MembershipTypesModel.FormatPriceInput(createInput.PriceAmount)"
                                   min="0"
                                   step="0.01"
                                   required />
                        </div>
                        <div class="form-field">
                            <label for="membership-type-currency">Currency</label>
                            <input id="membership-type-currency"
                                   name="form.PriceCurrency"
                                   type="text"
                                   value="@createInput.PriceCurrency"
                                   maxlength="12"
                                   required
                                   autocomplete="off" />
                        </div>
                        <div class="form-field form-field-span-2">
                            <label for="membership-type-comment">Comment</label>
                            <textarea id="membership-type-comment"
                                      name="form.Comment"
                                      rows="3">@createInput.Comment</textarea>
                        </div>
                        <div class="catalog-create-actions">
                            <button type="submit" data-busy-text="Adding...">Add membership type</button>
                        </div>
                    </div>
                </form>
            </section>
        }

        <section class="membership-type-list" aria-labelledby="membership-type-list-title">
            <header class="list-header">
                <div>
                    <h2 id="membership-type-list-title">Future sales catalog</h2>
                    <p class="list-breakdown">
                        <span>@Model.ActiveCount active</span>
                        <span>@Model.InactiveCount inactive</span>
                    </p>
                </div>
                <div class="catalog-list-summary">
                    @if (Model.CanManageCatalog)
                    {
                        <span class="status-chip status-owner">Owner managed</span>
                    }
                    <span class="list-count">
                        @Model.MembershipTypes.Count @(Model.MembershipTypes.Count == 1 ? "type" : "types")
                    </span>
                </div>
            </header>

            @if (Model.CatalogErrors.Count > 0)
            {
                <div class="command-error-summary" role="alert">
                    <strong>Catalog not updated</strong>
                    <ul>
                        @foreach (var message in Model.CatalogErrors.Select(DisplayEditError).Distinct(StringComparer.Ordinal))
                        {
                            <li>@message</li>
                        }
                    </ul>
                </div>
            }

            @if (Model.MembershipTypes.Count == 0)
            {
                <p class="empty-state">No membership types yet.</p>
            }
            else
            {
                @foreach (var membershipType in Model.MembershipTypes)
                {
                    var membershipTypeKey = membershipType.MembershipTypeId.ToString("N");

                    <article id="membership-type-@membershipTypeKey"
                             class="membership-type-row"
                             data-membership-type-id="@membershipType.MembershipTypeId"
                             data-membership-type-status="@(membershipType.IsActive ? "active" : "inactive")">
                        <header class="membership-type-header">
                            <h3>@membershipType.Name</h3>
                            <span class="status-chip @(membershipType.IsActive ? "status-active" : "status-inactive")">
                                @(membershipType.IsActive ? "Active" : "Inactive")
                            </span>
                        </header>

                        <dl class="membership-type-meta">
                            <div>
                                <dt>Duration</dt>
                                <dd>@membershipType.DurationDays days</dd>
                            </div>
                            <div>
                                <dt>Visit limit</dt>
                                <dd>@membershipType.VisitsLimit</dd>
                            </div>
                            <div>
                                <dt>Price</dt>
                                <dd>@MembershipTypesModel.FormatPrice(membershipType.Price)</dd>
                            </div>
                            <div>
                                <dt>Created</dt>
                                <dd>@MembershipTypesModel.FormatTimestamp(membershipType.CreatedAt)</dd>
                            </div>
                            <div>
                                <dt>Updated</dt>
                                <dd>@MembershipTypesModel.FormatTimestamp(membershipType.UpdatedAt)</dd>
                            </div>
                            <div>
                                <dt>Deactivated</dt>
                                <dd>
                                    @(membershipType.DeactivatedAt is { } deactivatedAt
                                        ? MembershipTypesModel.FormatTimestamp(deactivatedAt)
                                        : "Not deactivated")
                                </dd>
                            </div>
                            <div class="membership-type-comment">
                                <dt>Comment</dt>
                                <dd>@(membershipType.Comment ?? "No comment")</dd>
                            </div>
                        </dl>

                        @if (Model.CanEditCatalog
                            && Model.EditForms.TryGetValue(membershipType.MembershipTypeId, out var editForm))
                        {
                            var editInput = editForm.Input;

                            <details class="membership-type-edit-panel" open="@(editForm.IsOpen ? "open" : null)">
                                <summary>Edit catalog values</summary>
                                <div class="membership-type-edit-content">
                                    @if (editForm.Errors.Count > 0)
                                    {
                                        <div class="command-error-summary" role="alert">
                                            <strong>Membership type not updated</strong>
                                            <ul>
                                                @foreach (var message in editForm.Errors.Select(DisplayEditError).Distinct(StringComparer.Ordinal))
                                                {
                                                    <li>@message</li>
                                                }
                                            </ul>
                                        </div>
                                    }

                                    <form id="edit-membership-type-form-@membershipTypeKey"
                                          class="membership-type-edit-form"
                                          method="post"
                                          asp-page="/Owner/MembershipTypes"
                                          asp-page-handler="Edit"
                                          data-busy-form>
                                        <input type="hidden" name="form.MembershipTypeId" value="@editInput.MembershipTypeId" />
                                        <input type="hidden" name="form.ExpectedUpdatedAt" value="@editInput.ExpectedUpdatedAt.ToString("O")" />
                                        <input type="hidden" name="form.IdempotencyKey" value="@editInput.IdempotencyKey" />

                                        <div class="membership-type-edit-grid">
                                            <div class="form-field form-field-span-2">
                                                <label for="edit-membership-type-name-@membershipTypeKey">Name</label>
                                                <input id="edit-membership-type-name-@membershipTypeKey"
                                                       name="form.Name"
                                                       type="text"
                                                       value="@editInput.Name"
                                                       required
                                                       autocomplete="off" />
                                            </div>
                                            <div class="form-field">
                                                <label for="edit-membership-type-duration-@membershipTypeKey">Duration (days)</label>
                                                <input id="edit-membership-type-duration-@membershipTypeKey"
                                                       name="form.DurationDays"
                                                       type="number"
                                                       value="@editInput.DurationDays"
                                                       min="1"
                                                       step="1"
                                                       required />
                                            </div>
                                            <div class="form-field">
                                                <label for="edit-membership-type-visits-@membershipTypeKey">Visit limit</label>
                                                <input id="edit-membership-type-visits-@membershipTypeKey"
                                                       name="form.VisitsLimit"
                                                       type="number"
                                                       value="@editInput.VisitsLimit"
                                                       min="0"
                                                       step="1"
                                                       required />
                                            </div>
                                            <div class="form-field">
                                                <label for="edit-membership-type-price-@membershipTypeKey">Price amount</label>
                                                <input id="edit-membership-type-price-@membershipTypeKey"
                                                       name="form.PriceAmount"
                                                       type="number"
                                                       value="@MembershipTypesModel.FormatPriceInput(editInput.PriceAmount)"
                                                       min="0"
                                                       step="0.01"
                                                       required />
                                            </div>
                                            <div class="form-field">
                                                <label for="edit-membership-type-currency-@membershipTypeKey">Currency</label>
                                                <input id="edit-membership-type-currency-@membershipTypeKey"
                                                       name="form.PriceCurrency"
                                                       type="text"
                                                       value="@editInput.PriceCurrency"
                                                       maxlength="12"
                                                       required
                                                       autocomplete="off" />
                                            </div>
                                            <div class="form-field form-field-span-2">
                                                <label for="edit-membership-type-comment-@membershipTypeKey">Catalog comment</label>
                                                <textarea id="edit-membership-type-comment-@membershipTypeKey"
                                                          name="form.Comment"
                                                          rows="2">@editInput.Comment</textarea>
                                            </div>
                                            <div class="form-field form-field-span-full">
                                                <label for="edit-membership-type-reason-@membershipTypeKey">Reason for change</label>
                                                <textarea id="edit-membership-type-reason-@membershipTypeKey"
                                                          name="form.Reason"
                                                          rows="2"
                                                          maxlength="1000"
                                                          required>@editInput.Reason</textarea>
                                            </div>
                                            <div class="catalog-edit-actions">
                                                <button class="secondary-button"
                                                        type="submit"
                                                        data-busy-text="Saving...">Save changes</button>
                                            </div>
                                        </div>
                                    </form>
                                </div>
                            </details>
                        }
                    </article>
                }
            }
        </section>
    </section>
</main>

@functions {
    private static string DisplayCreateError(CommandError error)
    {
        return error.Code switch
        {
            CommandErrorCode.DuplicateSubmission =>
                "This submission key was already used. Refresh the catalog before creating another type.",
            CommandErrorCode.ConcurrencyConflict =>
                "The catalog changed concurrently. Review the refreshed catalog before trying again.",
            _ => RemoveParameterSuffix(error.Message),
        };
    }

    private static string DisplayEditError(CommandError error)
    {
        return error.Code switch
        {
            CommandErrorCode.StaleState =>
                "This membership type changed after the form was opened. Canonical values were reloaded; review them before saving again.",
            CommandErrorCode.ConcurrencyConflict =>
                "The catalog changed concurrently. Canonical values were reloaded; review them before saving again.",
            CommandErrorCode.DuplicateSubmission =>
                "This submission key was already used. Canonical values and a fresh key were loaded; review them before saving again.",
            CommandErrorCode.NotFound =>
                "The membership type was not found. The canonical catalog was refreshed.",
            _ => RemoveParameterSuffix(error.Message),
        };
    }

    private static string RemoveParameterSuffix(string message)
    {
        var parameterIndex = message.IndexOf("(Parameter '", StringComparison.Ordinal);
        return parameterIndex > 0
            ? message[..parameterIndex].TrimEnd()
            : message;
    }
}
