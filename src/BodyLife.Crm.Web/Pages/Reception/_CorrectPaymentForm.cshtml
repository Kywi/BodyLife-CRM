@using System.Globalization
@using BodyLife.Crm.Web.Localization
@inject Microsoft.Extensions.Localization.IStringLocalizer<global::BodyLife.Crm.Web.Localization.Reception> L
@model CorrectPaymentFormViewModel
@{
    var input = Model.Input;
    var payment = Model.Payment;
    var paymentKey = payment.PaymentId.ToString("N");
    var occurredDate = payment.OccurredAt.UtcDateTime.ToString("yyyy-MM-dd");
    var auditEntityId = payment.CorrectionFromOriginal?.OriginalPaymentId
        ?? input.OriginalPaymentId;
    var amountValue = input.ReplacementAmount?.ToString(CultureInfo.InvariantCulture);
    var occurredAtValue = input.ReplacementOccurredAtUtc?.ToString(
        "yyyy-MM-ddTHH:mm",
        CultureInfo.InvariantCulture);
    var replaceMode = input.Mode != PaymentCorrectionMode.Cancel;
}

<details id="correct-payment-panel-@paymentKey"
         class="payment-correction-panel"
         data-correct-payment-panel
         open="@(Model.IsOpen ? "open" : null)">
    <summary>@L["Payment.CorrectOrCancel"]</summary>
    <div class="payment-correction-content">
        @if (Model.Errors.Count > 0)
        {
            <div class="command-error-summary" role="alert">
                <strong>@L["Payment.CorrectionNotApplied"]</strong>
                <ul>
                    @foreach (var message in Model.Errors
                        .Select(error => ReceptionCommandErrorLocalizer.Display(L, error))
                        .Distinct(StringComparer.Ordinal))
                    {
                        <li>@message</li>
                    }
                </ul>
            </div>
        }

        <dl class="payment-correction-context">
            <div>
                <dt>@L["Payment.OriginalAmount"]</dt>
                <dd>@ReceptionDisplayFormatter.Money(payment.Amount)</dd>
            </div>
            <div>
                <dt>@L["Payment.OriginalContext"]</dt>
                <dd>@PaymentContextLabel(payment.PaymentContext)</dd>
            </div>
            <div>
                <dt>@L["Payment.OriginalDate"]</dt>
                <dd>@ReceptionDisplayFormatter.DateTime(payment.OccurredAt)</dd>
            </div>
            <div>
                <dt>@L["Payment.Method"]</dt>
                <dd>@L["Payment.Cash"]</dd>
            </div>
        </dl>

        <nav class="correction-record-links"
             aria-label="@L["Payment.CorrectionRecords"]"
             data-correction-record-links>
            <a class="secondary-link"
               asp-page="/Audit/ClientHistory"
               asp-route-clientId="@input.ClientId"
               asp-route-entity="@ClientHistoryEntityFilter.Payment"
               asp-route-from="@occurredDate"
               asp-route-to="@occurredDate"
               data-correction-history-link>
                @L["Visit.ClientHistory"]
            </a>
            <a class="secondary-link"
               asp-page="/Audit/Timeline"
               asp-route-clientId="@input.ClientId"
               asp-route-entity="@AuditTimelineEntityType.Payment"
               asp-route-entityId="@auditEntityId"
               data-correction-audit-link>
                @L["Visit.AuditTimeline"]
            </a>
        </nav>

        <div class="warning-block warning-danger">
            <strong>@L["Correction.KeepsHistory"]</strong>
            <span>@L["Payment.CorrectionHint"]</span>
        </div>

        <form id="correct-payment-form-@paymentKey"
              class="correct-payment-form"
              method="post"
              asp-page="/Reception/Index"
              asp-page-handler="CorrectPayment"
              data-busy-form
              data-correct-payment-form
              hx-post="@Url.Page("/Reception/Index", "CorrectPayment")"
              hx-target="#correct-payment-panel-@paymentKey"
              hx-swap="outerHTML"
              hx-sync="this:drop"
              hx-indicator="#correct-payment-loading-@paymentKey"
              hx-disabled-elt="find button">
            <input type="hidden" name="form.ClientId" value="@input.ClientId" />
            <input type="hidden" name="form.OriginalPaymentId" value="@input.OriginalPaymentId" />
            <input type="hidden" name="form.IdempotencyKey" value="@input.IdempotencyKey" />
            <input type="hidden" name="form.SearchQuery" value="@input.SearchQuery" />
            <input type="hidden" name="form.SearchMode" value="@input.SearchMode" />
            <input type="hidden" name="form.SearchIncludeInactive" value="@input.SearchIncludeInactive.ToString().ToLowerInvariant()" />
            <input type="hidden" name="form.SearchPageCursor" value="@input.SearchPageCursor" />

            <fieldset class="payment-correction-mode">
                <legend>@L["Payment.CorrectionMode"]</legend>
                <div class="payment-correction-segments">
                    <label>
                        <input type="radio"
                               name="form.Mode"
                               value="@PaymentCorrectionMode.Replace"
                               data-payment-correction-mode="replace"
                               checked="@(replaceMode ? "checked" : null)" />
                        <span>@L["Payment.Replace"]</span>
                    </label>
                    <label>
                        <input type="radio"
                               name="form.Mode"
                               value="@PaymentCorrectionMode.Cancel"
                               data-payment-correction-mode="cancel"
                               checked="@(!replaceMode ? "checked" : null)" />
                        <span>@L["Payment.Cancel"]</span>
                    </label>
                </div>
            </fieldset>

            <fieldset class="payment-replacement-fields"
                      data-payment-replacement-fields
                      data-active="@(replaceMode ? "true" : "false")">
                <legend>@L["Payment.Replacement"]</legend>
                <div class="action-form-grid">
                    <div class="form-field">
                        <label for="replacement-amount-@paymentKey">@L["Payment.ReplacementAmountUah"]</label>
                        <input id="replacement-amount-@paymentKey"
                               type="number"
                               name="form.ReplacementAmount"
                               value="@amountValue"
                               min="0.01"
                               step="0.01"
                               inputmode="decimal"
                               data-payment-replacement-input
                               data-payment-replacement-required
                               disabled="@(!replaceMode ? "disabled" : null)"
                               required="@(replaceMode ? "required" : null)" />
                    </div>

                    <div class="form-field">
                        <label for="replacement-context-@paymentKey">@L["Payment.ReplacementContext"]</label>
                        <select id="replacement-context-@paymentKey"
                                name="form.ReplacementPaymentContext"
                                data-payment-replacement-input
                                data-payment-replacement-required
                                disabled="@(!replaceMode ? "disabled" : null)"
                                required="@(replaceMode ? "required" : null)">
                            <option value="" selected="@(input.ReplacementPaymentContext is null ? "selected" : null)">@L["Payment.ChooseContext"]</option>
                            @foreach (var paymentContext in CorrectPaymentFormViewModel.SupportedContexts)
                            {
                                <option value="@paymentContext"
                                        selected="@(input.ReplacementPaymentContext == paymentContext ? "selected" : null)">
                                    @PaymentContextLabel(paymentContext)
                                </option>
                            }
                        </select>
                    </div>

                    <div class="form-field form-field-wide">
                        <label for="replacement-membership-@paymentKey">@L["Payment.ReplacementMembershipOptional"]</label>
                        <select id="replacement-membership-@paymentKey"
                                name="form.ReplacementMembershipId"
                                data-payment-replacement-input
                                disabled="@(!replaceMode ? "disabled" : null)">
                            <option value="" selected="@(input.ReplacementMembershipId is null ? "selected" : null)">@L["Payment.NoMembership"]</option>
                            @foreach (var membership in Model.MembershipOptions)
                            {
                                <option value="@membership.MembershipId"
                                        selected="@(input.ReplacementMembershipId == membership.MembershipId ? "selected" : null)">
                                    @membership.TypeNameSnapshot | @MembershipStatusLabel(membership.Status) | @L["Payment.Ends"] @ReceptionDisplayFormatter.Date(membership.EffectiveEndDate)
                                </option>
                            }
                        </select>
                    </div>

                    <div class="form-field form-field-wide">
                        <label for="replacement-occurred-at-@paymentKey">@L["Payment.ReplacementOccurredUtc"]</label>
                        <input id="replacement-occurred-at-@paymentKey"
                               type="datetime-local"
                               name="form.ReplacementOccurredAtUtc"
                               value="@occurredAtValue"
                               step="60"
                               data-payment-replacement-input
                               data-payment-replacement-required
                               disabled="@(!replaceMode ? "disabled" : null)"
                               required="@(replaceMode ? "required" : null)" />
                    </div>

                    <div class="form-field form-field-wide">
                        <label for="replacement-comment-@paymentKey">@L["Payment.ReplacementCommentOptional"]</label>
                        <textarea id="replacement-comment-@paymentKey"
                                  name="form.ReplacementComment"
                                  maxlength="@CorrectPaymentFormViewModel.CommentMaxLength"
                                  data-payment-replacement-input
                                  disabled="@(!replaceMode ? "disabled" : null)">@input.ReplacementComment</textarea>
                    </div>
                </div>
            </fieldset>

            <div class="form-field">
                <label for="correct-payment-reason-@paymentKey">@L["Field.Reason"]</label>
                <textarea id="correct-payment-reason-@paymentKey"
                          name="form.Reason"
                          maxlength="@CorrectPaymentFormViewModel.ReasonMaxLength"
                          required>@input.Reason</textarea>
            </div>

            <div class="form-field">
                <label for="correct-payment-comment-@paymentKey">@L["Payment.CorrectionCommentOptional"]</label>
                <textarea id="correct-payment-comment-@paymentKey"
                          name="form.Comment"
                          maxlength="@CorrectPaymentFormViewModel.CommentMaxLength">@input.Comment</textarea>
            </div>

            <label class="acknowledgement-control correct-payment-confirmation"
                   for="correct-payment-confirmed-@paymentKey">
                <input id="correct-payment-confirmed-@paymentKey"
                       type="checkbox"
                       name="form.Confirmed"
                       value="true"
                       checked="@(input.Confirmed ? "checked" : null)"
                       required />
                <span>@L["Payment.CorrectionConfirm"]</span>
            </label>

            <div class="action-form-footer">
                <span id="correct-payment-loading-@paymentKey"
                      class="request-indicator htmx-indicator"
                      role="status"
                      aria-live="polite">@L["Payment.ApplyingCorrection"]</span>
                <button class="danger-button"
                        type="submit"
                        data-correct-payment-submit
                        data-busy-text="@L["Action.Applying"]">@L["Payment.ApplyCorrection"]</button>
            </div>
        </form>
    </div>
</details>

@functions {
    private string PaymentContextLabel(PaymentContext paymentContext)
    {
        return paymentContext switch
        {
            PaymentContext.MembershipSale => L["Payment.Context.MembershipSale"],
            PaymentContext.OneOff => L["Payment.Context.OneOff"],
            PaymentContext.Trial => L["Payment.Context.Trial"],
            PaymentContext.Other => L["Payment.Context.Other"],
            _ => L["Error.Generic"],
        };
    }

    private string MembershipStatusLabel(string status)
    {
        return status switch
        {
            ClientMembershipSummaryStatusCodes.Active => L["Status.Active"],
            ClientMembershipSummaryStatusCodes.Expired => L["Status.Expired"],
            ClientMembershipSummaryStatusCodes.Canceled => L["Status.Canceled"],
            ClientMembershipSummaryStatusCodes.Corrected => L["Status.Corrected"],
            _ => L["Error.Generic"],
        };
    }
}
