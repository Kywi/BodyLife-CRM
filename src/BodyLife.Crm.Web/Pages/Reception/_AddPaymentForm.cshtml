@using System.Globalization
@using BodyLife.Crm.Web.Localization
@inject Microsoft.Extensions.Localization.IStringLocalizer<global::BodyLife.Crm.Web.Localization.Reception> L
@model AddPaymentFormViewModel
@{
    var input = Model.Input;
    var clientKey = input.ClientId.ToString("N");
    var amountValue = input.Amount?.ToString(CultureInfo.InvariantCulture);
    var occurredAtValue = input.OccurredAtLocal?.ToString("yyyy-MM-ddTHH:mm", CultureInfo.InvariantCulture);
}

<details id="add-payment-action-panel"
         class="profile-action-panel"
         open="@(Model.IsOpen ? "open" : null)">
    <summary>@L["Payment.Add"]</summary>
    <div class="profile-action-content">
        @if (Model.Errors.Count > 0)
        {
            <div class="command-error-summary" role="alert">
                <strong>@L["Payment.NotAdded"]</strong>
                <ul>
                    @foreach (var message in Model.Errors
                        .Select(error => ReceptionCommandErrorLocalizer.Display(L, error))
                        .Distinct(StringComparer.Ordinal))
                    {
                        <li>@message</li>
                    }
                </ul>
            </div>
        }

        <div class="warning-block warning-caution">
            <strong>@L["Payment.StateUnchanged"]</strong>
            <span>@L["Payment.StateUnchangedHint"]</span>
        </div>

        <form id="add-payment-form-@clientKey"
              class="add-payment-form"
              method="post"
              asp-page="/Reception/Index"
              asp-page-handler="CreatePayment"
              data-busy-form
              hx-post="@Url.Page("/Reception/Index", "CreatePayment")"
              hx-target="#add-payment-action-panel"
              hx-swap="outerHTML"
              hx-sync="this:drop"
              hx-indicator="#add-payment-loading"
              hx-disabled-elt="find button">
            <input type="hidden" name="form.ClientId" value="@input.ClientId" />
            <input type="hidden" name="form.IdempotencyKey" value="@input.IdempotencyKey" />
            <input type="hidden" name="form.SearchQuery" value="@input.SearchQuery" />
            <input type="hidden" name="form.SearchMode" value="@input.SearchMode" />
            <input type="hidden" name="form.SearchIncludeInactive" value="@input.SearchIncludeInactive.ToString().ToLowerInvariant()" />
            <input type="hidden" name="form.SearchPageCursor" value="@input.SearchPageCursor" />

            <dl class="payment-fixed-context">
                <div>
                    <dt>@L["Payment.Method"]</dt>
                    <dd>@L["Payment.Cash"]</dd>
                </div>
                <div>
                    <dt>@L["Payment.Currency"]</dt>
                    <dd>@AddPaymentFormViewModel.Currency</dd>
                </div>
            </dl>

            <div class="action-form-grid">
                <div class="form-field">
                    <label for="payment-amount-@clientKey">@L["Payment.AmountUah"]</label>
                    <input id="payment-amount-@clientKey"
                           type="number"
                           name="form.Amount"
                           value="@amountValue"
                           min="0.01"
                           step="0.01"
                           inputmode="decimal"
                           required />
                </div>

                <div class="form-field">
                    <label for="payment-context-@clientKey">@L["Payment.Context"]</label>
                    <select id="payment-context-@clientKey"
                            name="form.PaymentContext"
                            required>
                        <option value="" selected="@(input.PaymentContext is null ? "selected" : null)">@L["Payment.ChooseContext"]</option>
                        @foreach (var paymentContext in AddPaymentFormViewModel.SupportedContexts)
                        {
                            <option value="@paymentContext"
                                    selected="@(input.PaymentContext == paymentContext ? "selected" : null)">
                                @PaymentContextLabel(paymentContext)
                            </option>
                        }
                    </select>
                </div>

                <div class="form-field form-field-wide">
                    <label for="payment-membership-@clientKey">@L["Payment.MembershipOptional"]</label>
                    <select id="payment-membership-@clientKey" name="form.MembershipId">
                        <option value="" selected="@(input.MembershipId is null ? "selected" : null)">@L["Payment.NoMembership"]</option>
                        @foreach (var membership in Model.MembershipOptions)
                        {
                            <option value="@membership.MembershipId"
                                    selected="@(input.MembershipId == membership.MembershipId ? "selected" : null)">
                                @membership.TypeNameSnapshot | @MembershipStatusLabel(membership.Status) | @L["Payment.Ends"] @ReceptionDisplayFormatter.Date(membership.EffectiveEndDate)
                            </option>
                        }
                    </select>
                </div>

                <div class="form-field form-field-wide">
                    <label for="payment-occurred-at-@clientKey">@L["Payment.OccurredLocal"]</label>
                    <input id="payment-occurred-at-@clientKey"
                           type="datetime-local"
                           name="form.OccurredAtLocal"
                           value="@occurredAtValue"
                           step="60"
                           required />
                </div>

                <div class="form-field form-field-wide">
                    <label for="payment-comment-@clientKey">@L["Field.CommentOptional"]</label>
                    <textarea id="payment-comment-@clientKey"
                              name="form.Comment"
                              maxlength="@AddPaymentFormViewModel.CommentMaxLength">@input.Comment</textarea>
                </div>
            </div>

            <div class="action-form-footer">
                <span id="add-payment-loading"
                      class="request-indicator htmx-indicator"
                      role="status"
                      aria-live="polite">@L["Payment.Adding"]</span>
                <button type="submit"
                        data-add-payment-submit
                        data-busy-text="@L["Action.Adding"]">@L["Payment.Add"]</button>
            </div>
        </form>
    </div>
</details>

@functions {
    private string PaymentContextLabel(PaymentContext paymentContext)
    {
        return paymentContext switch
        {
            PaymentContext.MembershipSale => L["Payment.Context.MembershipSale"],
            PaymentContext.OneOff => L["Payment.Context.OneOff"],
            PaymentContext.Trial => L["Payment.Context.Trial"],
            PaymentContext.Other => L["Payment.Context.Other"],
            _ => L["Error.Generic"],
        };
    }

    private string MembershipStatusLabel(string status)
    {
        return status switch
        {
            ClientMembershipSummaryStatusCodes.Active => L["Status.Active"],
            ClientMembershipSummaryStatusCodes.Expired => L["Status.Expired"],
            ClientMembershipSummaryStatusCodes.Canceled => L["Status.Canceled"],
            ClientMembershipSummaryStatusCodes.Corrected => L["Status.Corrected"],
            _ => L["Error.Generic"],
        };
    }
}
