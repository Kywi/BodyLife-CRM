@page
@model BodyLife.Crm.Web.Pages.Reception.IndexModel
@using BodyLife.Crm.Web.Localization
@inject Microsoft.Extensions.Localization.IStringLocalizer<Reception> L
@{
    ViewData["Title"] = L["Dashboard.Title"];
}

<main class="page-shell reception-page">
    <section class="reception-layout" aria-labelledby="reception-title">
        <header class="reception-header">
            <div>
                <p class="eyebrow">BodyLife CRM</p>
                <h1 id="reception-title">@L["Dashboard.Title"]</h1>
            </div>
        </header>

        <section class="search-island" aria-labelledby="client-search-label">
            <form id="reception-search"
                  class="search-panel"
                  method="get"
                  asp-page="/Reception/Index"
                  role="search"
                  hx-get="@Url.Page("/Reception/Index", "Search")"
                  hx-target="#reception-workspace"
                  hx-swap="outerHTML"
                  hx-sync="this:replace"
                  hx-indicator="#search-loading"
                  hx-disabled-elt="find button">
                <div class="search-primary-row">
                    <div class="search-field">
                        <label id="client-search-label" for="client-search">@L["Search.Label"]</label>
                        <input id="client-search"
                               name="q"
                               type="search"
                               value="@Model.Query"
                               autocomplete="off"
                               maxlength="200"
                               placeholder="@L["Search.Placeholder"]"
                               required />
                    </div>
                    <div class="search-command-group">
                        <button type="submit">@L["Action.Search"]</button>
                        <a class="secondary-link" asp-page="/Reception/Index">@L["Action.Clear"]</a>
                    </div>
                </div>

                <div class="search-options">
                    <fieldset class="search-mode-control">
                        <legend>@L["Search.Mode"]</legend>
                        <div class="search-mode-segments">
                            <label>
                                <input type="radio"
                                       name="mode"
                                       value="Auto"
                                       checked="@(Model.Mode == ClientSearchMode.Auto ? "checked" : null)" />
                                <span>@L["Search.Mode.Auto"]</span>
                            </label>
                            <label>
                                <input type="radio"
                                       name="mode"
                                       value="Card"
                                       checked="@(Model.Mode == ClientSearchMode.Card ? "checked" : null)" />
                                <span>@L["Search.Mode.Card"]</span>
                            </label>
                            <label>
                                <input type="radio"
                                       name="mode"
                                       value="Name"
                                       checked="@(Model.Mode == ClientSearchMode.Name ? "checked" : null)" />
                                <span>@L["Search.Mode.Name"]</span>
                            </label>
                            <label>
                                <input type="radio"
                                       name="mode"
                                       value="Phone"
                                       checked="@(Model.Mode == ClientSearchMode.Phone ? "checked" : null)" />
                                <span>@L["Search.Mode.Phone"]</span>
                            </label>
                            <label>
                                <input type="radio"
                                       name="mode"
                                       value="LastFour"
                                       checked="@(Model.Mode == ClientSearchMode.LastFour ? "checked" : null)" />
                                <span>@L["Search.Mode.LastFour"]</span>
                            </label>
                        </div>
                    </fieldset>

                    <label class="checkbox-control">
                        <input type="checkbox"
                               name="includeInactive"
                               value="true"
                               checked="@(Model.IncludeInactive ? "checked" : null)" />
                        <span>@L["Search.IncludeInactive"]</span>
                    </label>

                    <span id="search-loading"
                          class="request-indicator htmx-indicator"
                          role="status"
                          aria-live="polite">@L["Search.Loading"]</span>
                </div>
            </form>
        </section>

        <partial name="_ReceptionWorkspace" model="Model.Workspace" />
    </section>
</main>
