@using System.Globalization
@using BodyLife.Crm.Web.Localization
@inject Microsoft.Extensions.Localization.IStringLocalizer<global::BodyLife.Crm.Web.Localization.Reception> L
@inject Microsoft.Extensions.Localization.IStringLocalizer<global::BodyLife.Crm.Web.Localization.Shared> S
@using BodyLife.Crm.Modules.MembershipTypes
@model IssueMembershipFormViewModel
@{
    var input = Model.Input;
    var preview = Model.Preview;
    var clientKey = input.ClientId.ToString("N");
    var formId = $"issue-membership-form-{clientKey}";
    var startDateValue = input.StartDate?.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture);
    var paymentAmountValue = input.PaymentAmount?.ToString(CultureInfo.InvariantCulture);
    var previewUrl = Url.Page("/Reception/Index", "IssueMembershipPreview");
}

<details id="issue-membership-action-panel"
         class="profile-action-panel"
         open="@(Model.IsOpen ? "open" : null)">
    <summary>@L["Membership.Issue"]</summary>
    <div class="profile-action-content">
        @if (Model.Errors.Count > 0)
        {
            <div class="command-error-summary" role="alert">
                <strong>@L["Membership.NotIssued"]</strong>
                <ul>
                    @foreach (var message in Model.Errors
                        .Select(error => ReceptionCommandErrorLocalizer.Display(L, error))
                        .Distinct(StringComparer.Ordinal))
                    {
                        <li>@message</li>
                    }
                </ul>
            </div>
        }

        @if (Model.MembershipTypesResult.Status != GetMembershipTypesForIssueStatus.Success)
        {
            <div class="warning-block warning-danger" role="alert">
                <strong>@L["Membership.IssueUnavailable"]</strong>
                <span>@L["Error.Generic"]</span>
            </div>
        }
        else if (Model.MembershipTypes.Count == 0)
        {
            <div class="warning-block warning-caution" role="status">
                <strong>@L["Membership.NoActiveTypes"]</strong>
                <span>@L["Membership.NoActiveTypesHint"]</span>
            </div>
        }
        else
        {
            <form id="@formId"
                  class="issue-membership-form"
                  method="post"
                  asp-page="/Reception/Index"
                  asp-page-handler="IssueMembership"
                  data-busy-form
                  data-issue-membership-form
                  data-can-submit="@Model.CanSubmit.ToString().ToLowerInvariant()"
                  hx-post="@Url.Page("/Reception/Index", "IssueMembership")"
                  hx-target="#issue-membership-action-panel"
                  hx-swap="outerHTML"
                  hx-sync="this:drop"
                  hx-indicator="#issue-membership-loading"
                  hx-disabled-elt="find button">
                <input type="hidden" name="form.ClientId" value="@input.ClientId" />
                <input type="hidden" name="form.IdempotencyKey" value="@input.IdempotencyKey" />
                <input type="hidden" name="form.SearchQuery" value="@input.SearchQuery" />
                <input type="hidden" name="form.SearchMode" value="@input.SearchMode" />
                <input type="hidden" name="form.SearchIncludeInactive" value="@input.SearchIncludeInactive.ToString().ToLowerInvariant()" />
                <input type="hidden" name="form.SearchPageCursor" value="@input.SearchPageCursor" />

                <div class="action-form-grid issue-membership-inputs">
                    <div class="form-field">
                        <label for="membership-type-@clientKey">@L["Membership.Type"]</label>
                        <select id="membership-type-@clientKey"
                                name="form.MembershipTypeId"
                                required
                                hx-get="@previewUrl"
                                hx-trigger="change"
                                hx-include="#@formId [name^='form.']"
                                hx-target="#issue-membership-action-panel"
                                hx-swap="outerHTML"
                                hx-sync="#@formId:replace"
                                hx-indicator="#issue-membership-preview-loading">
                            @foreach (var membershipType in Model.MembershipTypes)
                            {
                                <option value="@membershipType.MembershipTypeId"
                                        selected="@(input.MembershipTypeId == membershipType.MembershipTypeId ? "selected" : null)">
                                    @membershipType.Name
                                </option>
                            }
                        </select>
                    </div>

                    <div class="form-field">
                        <label for="membership-start-date-@clientKey">@L["Field.StartDate"]</label>
                        <input id="membership-start-date-@clientKey"
                               type="date"
                               name="form.StartDate"
                               value="@startDateValue"
                               required
                               hx-get="@previewUrl"
                               hx-trigger="change"
                               hx-include="#@formId [name^='form.']"
                               hx-target="#issue-membership-action-panel"
                               hx-swap="outerHTML"
                               hx-sync="#@formId:replace"
                               hx-indicator="#issue-membership-preview-loading" />
                    </div>
                </div>

                @if (Model.PreviewResult is { Status: not PreviewIssueMembershipStatus.Success })
                {
                    <div class="warning-block warning-danger" role="alert">
                        <strong>@L["Preview.Unavailable"]</strong>
                        <span>@L["Error.Generic"]</span>
                    </div>
                }
                else if (preview is not null)
                {
                    <section class="issue-membership-preview" aria-labelledby="issue-membership-preview-title-@clientKey">
                        <header class="issue-membership-preview-header">
                            <h4 id="issue-membership-preview-title-@clientKey">@L["Membership.IssuePreview"]</h4>
                            <span id="issue-membership-preview-loading"
                                  class="request-indicator htmx-indicator"
                                  role="status"
                                  aria-live="polite">@L["Preview.Refreshing"]</span>
                        </header>

                        <dl class="issue-membership-snapshot">
                            <div>
                                <dt>@L["Membership.SnapshotName"]</dt>
                                <dd>@preview.Snapshot.TypeName</dd>
                            </div>
                            <div>
                                <dt>@L["Membership.Duration"]</dt>
                                <dd>@WebPluralizer.Days(S, preview.Snapshot.DurationDays)</dd>
                            </div>
                            <div>
                                <dt>@L["Membership.VisitLimit"]</dt>
                                <dd>@preview.Snapshot.VisitsLimit</dd>
                            </div>
                            <div>
                                <dt>@L["Membership.SnapshotPrice"]</dt>
                                <dd>@MoneyLabel(preview.Snapshot.Price)</dd>
                            </div>
                            <div>
                                <dt>@L["Membership.BaseEnd"]</dt>
                                <dd data-issue-preview-base-end
                                    data-iso-date="@preview.BaseEndDate.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture)">@ReceptionDisplayFormatter.Date(preview.BaseEndDate)</dd>
                            </div>
                            <div>
                                <dt>@L["Profile.EffectiveEnd"]</dt>
                                <dd>@ReceptionDisplayFormatter.Date(preview.ExpectedInitialEffectiveEndDate)</dd>
                            </div>
                            <div>
                                <dt>@L["Membership.InitialRemaining"]</dt>
                                <dd>@preview.ExpectedInitialRemainingVisits</dd>
                            </div>
                            <div>
                                <dt>@L["Membership.ExtensionDays"]</dt>
                                <dd>@preview.ExpectedInitialExtensionDays</dd>
                            </div>
                        </dl>

                        @foreach (var warning in preview.Warnings)
                        {
                            <div class="warning-block @WarningClass(warning.Severity)">
                                <strong>@WarningTitle(warning.Code)</strong>
                                <span>@WarningMessage(warning.Code)</span>
                            </div>
                        }

                        @if (preview.ExistingNegativeState is { } negativeState)
                        {
                            <fieldset class="issue-negative-decision">
                                <legend>@L["Membership.ExistingNegativeVisits"]</legend>
                                <p>
                                    @L["Membership.NegativeBalance", negativeState.NegativeBalance]
                                    @if (negativeState.FirstNegativeVisitDate is { } firstNegativeDate)
                                    {
                                        <span>@L["Membership.NegativeSince", ReceptionDisplayFormatter.Date(firstNegativeDate)]</span>
                                    }
                                </p>
                                <div class="issue-negative-options">
                                    @foreach (var option in preview.NegativeHandlingOptions)
                                    {
                                        <label class="@(option.IsAvailable ? null : "issue-negative-option-disabled")">
                                            <input type="radio"
                                                   name="form.NegativeHandlingDecision"
                                                   value="@option.Decision"
                                                   checked="@(input.NegativeHandlingDecision == option.Decision ? "checked" : null)"
                                                   disabled="@(!option.IsAvailable ? "disabled" : null)"
                                                   required="@(preview.RequiresNegativeHandlingDecision && option.IsAvailable ? "required" : null)"
                                                   hx-get="@previewUrl"
                                                   hx-trigger="change"
                                                   hx-include="#@formId [name^='form.']"
                                                   hx-target="#issue-membership-action-panel"
                                                   hx-swap="outerHTML"
                                                   hx-sync="#@formId:replace"
                                                   hx-indicator="#issue-membership-preview-loading" />
                                            <span>
                                                <strong>@NegativeDecisionLabel(option.Decision)</strong>
                                                @if (!option.IsAvailable)
                                                {
                                                    <small>@L["Status.Unavailable"]</small>
                                                }
                                            </span>
                                        </label>
                                    }
                                </div>
                            </fieldset>
                        }
                    </section>
                }

                <fieldset class="issue-payment-choice">
                    <legend>@L["Field.Payment"]</legend>
                    <label class="issue-payment-toggle" for="issue-payment-toggle-@clientKey">
                        <input id="issue-payment-toggle-@clientKey"
                               type="checkbox"
                               name="form.IncludePayment"
                               value="true"
                               checked="@(input.IncludePayment ? "checked" : null)"
                               data-issue-payment-toggle />
                        <span>@L["Membership.AddSalePayment"]</span>
                    </label>

                    <div class="issue-payment-fields" data-issue-payment-fields>
                        <dl class="payment-fixed-context">
                            <div>
                                <dt>@L["Payment.Method"]</dt>
                                <dd>@L["Payment.Cash"]</dd>
                            </div>
                            <div>
                                <dt>@L["Payment.Currency"]</dt>
                                <dd>@IssueMembershipFormViewModel.Currency</dd>
                            </div>
                            <div>
                                <dt>@L["Field.Context"]</dt>
                                <dd>@L["Payment.Context.MembershipSale"]</dd>
                            </div>
                        </dl>
                        <div class="form-field">
                            <label for="issue-payment-amount-@clientKey">@L["Payment.AmountUah"]</label>
                            <input id="issue-payment-amount-@clientKey"
                                   type="number"
                                   name="form.PaymentAmount"
                                   value="@paymentAmountValue"
                                   min="0.01"
                                   step="0.01"
                                   inputmode="decimal"
                                   disabled="@(!input.IncludePayment ? "disabled" : null)"
                                   required="@(input.IncludePayment ? "required" : null)"
                                   data-issue-payment-input />
                        </div>
                    </div>
                </fieldset>

                <div class="form-field">
                    <label for="issue-membership-comment-@clientKey">@L["Field.CommentOptional"]</label>
                    <textarea id="issue-membership-comment-@clientKey"
                              name="form.Comment"
                              maxlength="@IssueMembershipFormViewModel.CommentMaxLength">@input.Comment</textarea>
                </div>

                <div class="action-form-footer">
                    <span id="issue-membership-loading"
                          class="request-indicator htmx-indicator"
                          role="status"
                          aria-live="polite">@L["Membership.Issuing"]</span>
                    <button type="submit"
                            data-issue-membership-submit
                            data-busy-text="@L["Membership.IssuingShort"]"
                            disabled="@(!Model.CanSubmit ? "disabled" : null)">@L["Membership.Issue"]</button>
                </div>
            </form>
        }
    </div>
</details>

@functions {
    private static string MoneyLabel(Money money)
    {
        return ReceptionDisplayFormatter.Money(money);
    }

    private static string WarningClass(MembershipWarningSeverity severity)
    {
        return severity == MembershipWarningSeverity.Danger
            ? "warning-danger"
            : "warning-caution";
    }

    private string WarningTitle(string code)
    {
        return code switch
        {
            MembershipWarningCodes.NegativeBalance => L["Warning.NegativeBalance.Title"],
            MembershipWarningCodes.ExpiredByDate => L["Warning.Expired.Title"],
            MembershipWarningCodes.ZeroRemaining => L["Warning.ZeroRemaining.Title"],
            MembershipWarningCodes.EndingSoon => L["Warning.EndingSoon.Title"],
            MembershipWarningCodes.LowRemaining => L["Warning.LowRemaining.Title"],
            _ => L["Warning.Attention"],
        };
    }

    private string WarningMessage(string code)
    {
        return code switch
        {
            MembershipWarningCodes.NegativeBalance => L["Warning.NegativeBalance.Message"],
            MembershipWarningCodes.ExpiredByDate => L["Warning.Expired.Message"],
            MembershipWarningCodes.ZeroRemaining => L["Warning.ZeroRemaining.Message"],
            MembershipWarningCodes.EndingSoon => L["Warning.EndingSoon.Message"],
            MembershipWarningCodes.LowRemaining => L["Warning.LowRemaining.Message"],
            _ => L["Warning.Generic.Message"],
        };
    }

    private string NegativeDecisionLabel(MembershipNegativeHandlingDecision decision)
    {
        return decision switch
        {
            MembershipNegativeHandlingDecision.LeaveVisible => L["Membership.NegativeDecision.LeaveVisible"],
            MembershipNegativeHandlingDecision.CoverWithNewMembership => L["Membership.NegativeDecision.Cover"],
            MembershipNegativeHandlingDecision.RecordExplicitClosure => L["Membership.NegativeDecision.Closure"],
            _ => L["Value.Unknown"],
        };
    }
}
