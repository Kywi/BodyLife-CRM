@model ClientProfileViewModel
@{
    var result = Model.Result;
    var profile = result?.Profile;
    var correctPaymentFormsByPaymentId = Model.CorrectPaymentForms.ToDictionary(
        form => form.Input.OriginalPaymentId);
    var cancelFreezeFormsByFreezeId = Model.CancelFreezeForms.ToDictionary(
        form => form.Input.FreezeId);
}

<section id="client-profile" class="client-profile-region" aria-label="Client profile" aria-live="polite">
    <span id="profile-loading"
          class="request-indicator profile-loading htmx-indicator"
          role="status"
          aria-live="polite">Loading client...</span>

    @if (result is null)
    {
        <div class="operational-empty profile-empty">
            <h2>No client selected</h2>
            <a class="secondary-link" asp-page="/Reports/Daily">Open daily report</a>
        </div>
    }
    else if (result.Status != GetClientProfileStatus.Success || profile is null)
    {
        <div class="warning-block warning-danger" role="alert">
            <strong>Client unavailable</strong>
            <span>@result.ErrorMessage</span>
        </div>
    }
    else
    {
        var extensionMemberships = profile.Membership.Timeline
            .Where(membership => membership.ExtensionExplanations.Count > 0)
            .ToArray();

        <header class="client-identity-header">
            <div>
                <p class="eyebrow">Client profile</p>
                <h2>@profile.DisplayName</h2>
            </div>
            <span class="status-chip @(profile.OperationalStatus == ClientOperationalStatus.Active ? "status-active" : "status-inactive")">
                @(profile.OperationalStatus == ClientOperationalStatus.Active ? "Active" : "Inactive")
            </span>
        </header>

        @if (!string.IsNullOrWhiteSpace(Model.OperationMessage))
        {
            <div class="operation-message profile-operation-message @(Model.OperationSucceeded ? "operation-success" : "operation-error")"
                 role="@(Model.OperationSucceeded ? "status" : "alert")">
                @Model.OperationMessage
            </div>
        }

        @if (profile.Warnings.Count > 0)
        {
            <div class="profile-warning-list" aria-label="Profile warnings">
                @foreach (var warning in profile.Warnings)
                {
                    <div class="warning-block warning-caution">
                        <strong>@WarningLabel(warning.Code)</strong>
                        <span>@warning.Message</span>
                    </div>
                }
            </div>
        }

        <dl class="client-profile-meta">
            <div>
                <dt>Current card</dt>
                <dd>@(profile.CurrentCard?.CardNumber ?? "No current card")</dd>
            </div>
            <div>
                <dt>Phone</dt>
                <dd>@(profile.Phone ?? "No phone")</dd>
            </div>
            <div>
                <dt>Updated</dt>
                <dd>@profile.UpdatedAt.ToString("yyyy-MM-dd HH:mm") UTC</dd>
            </div>
            @if (profile.CurrentCard is not null)
            {
                <div>
                    <dt>Card assigned</dt>
                    <dd>@profile.CurrentCard.AssignedAt.ToString("yyyy-MM-dd HH:mm") UTC</dd>
                </div>
            }
        </dl>

        @if (profile.Comment is not null)
        {
            <section class="client-comment" aria-labelledby="client-comment-title">
                <h3 id="client-comment-title">Reception note</h3>
                <p>@profile.Comment</p>
            </section>
        }

        <section class="membership-panel" aria-labelledby="membership-panel-title">
            <header class="membership-panel-header">
                <h3 id="membership-panel-title">Current membership</h3>
            </header>

            @if (profile.Membership.CurrentMembership is null)
            {
                <p class="membership-empty">No current membership</p>
            }
            else
            {
                var membership = profile.Membership.CurrentMembership;
                <dl class="membership-summary-grid">
                    <div>
                        <dt>Status</dt>
                        <dd>@membership.Status</dd>
                    </div>
                    <div>
                        <dt>Remaining visits</dt>
                        <dd>@membership.RemainingVisits</dd>
                    </div>
                    <div>
                        <dt>Effective end</dt>
                        <dd>@membership.EffectiveEndDate.ToString("yyyy-MM-dd")</dd>
                    </div>
                </dl>
            }

            @if (profile.Membership.Warnings.Count > 0)
            {
                <div class="profile-warning-list" aria-label="Membership warnings">
                    @foreach (var warning in profile.Membership.Warnings)
                    {
                        <div class="warning-block warning-caution">
                            <strong>@WarningLabel(warning.Code)</strong>
                            <span>@warning.Message</span>
                        </div>
                    }
                </div>
            }

            @if (extensionMemberships.Length > 0)
            {
                <section class="membership-extension-history"
                         aria-labelledby="membership-extension-history-title"
                         data-membership-extension-history>
                    <header class="membership-extension-history-header">
                        <div>
                            <p class="eyebrow">Membership timeline</p>
                            <h4 id="membership-extension-history-title">Extension history</h4>
                        </div>
                    </header>

                    @foreach (var timelineMembership in extensionMemberships)
                    {
                        <div class="membership-extension-group"
                             data-membership-extension-group
                             data-membership-id="@timelineMembership.MembershipId"
                             data-membership-status="@timelineMembership.Status">
                            <header class="membership-extension-group-header">
                                <h5>@timelineMembership.TypeNameSnapshot</h5>
                                <span class="status-chip @MembershipStatusClass(timelineMembership.Status)">
                                    @MembershipStatusLabel(timelineMembership.Status)
                                </span>
                            </header>

                            <ol class="membership-extension-list">
                                @foreach (var explanation in timelineMembership.ExtensionExplanations)
                                {
                                    <li class="membership-extension-row @ExtensionStatusRowClass(explanation.Status)"
                                        data-extension-source-kind="@ExtensionSourceKindCode(explanation.SourceKind)"
                                        data-extension-source-status="@ExtensionSourceStatusCode(explanation.Status)"
                                        data-extension-source-id="@explanation.SourceId">
                                        <header class="membership-extension-row-header">
                                            <div>
                                                <p class="membership-extension-kind">Extension source</p>
                                                <h6>@ExtensionSourceKindLabel(explanation.SourceKind)</h6>
                                            </div>
                                            <span class="status-chip @ExtensionSourceStatusClass(explanation.Status)">
                                                @ExtensionSourceStatusLabel(explanation.Status)
                                            </span>
                                        </header>

                                        <dl class="membership-extension-meta">
                                            <div>
                                                <dt>Inclusive range</dt>
                                                <dd data-extension-inclusive-range>
                                                    @explanation.Range.StartDate.ToString("yyyy-MM-dd") to @explanation.Range.EndDate.ToString("yyyy-MM-dd")
                                                </dd>
                                            </div>
                                            <div>
                                                <dt>Reason</dt>
                                                <dd>@explanation.ReasonLabel</dd>
                                            </div>
                                        </dl>

                                        @if (cancelFreezeFormsByFreezeId.TryGetValue(
                                            explanation.SourceId,
                                            out var cancelFreezeForm))
                                        {
                                            <partial name="_CancelFreezeForm" model="cancelFreezeForm" />
                                        }
                                    </li>
                                }
                            </ol>
                        </div>
                    }
                </section>
            }
        </section>

        @if (Model.IssueMembershipForm is not null)
        {
            <partial name="_IssueMembershipForm" model="Model.IssueMembershipForm" />
        }

        @if (Model.MarkVisitForm is not null)
        {
            <partial name="_MarkVisitForm" model="Model.MarkVisitForm" />
        }

        @if (Model.AddFreezeForm is not null)
        {
            <partial name="_AddFreezeForm" model="Model.AddFreezeForm" />
        }

        @if (Model.AddPaymentForm is not null)
        {
            <partial name="_AddPaymentForm" model="Model.AddPaymentForm" />
        }

        @if (profile.RecentVisits is { } recentVisits)
        {
            <section class="recent-visits" aria-labelledby="recent-visits-title">
                <header class="recent-visits-header">
                    <h3 id="recent-visits-title">Recent visits</h3>
                    @if (recentVisits.HasMore)
                    {
                        <span class="result-count">Latest @recentVisits.Items.Count</span>
                    }
                </header>

                @if (recentVisits.Items.Count == 0)
                {
                    <p class="recent-visits-empty">No visits recorded</p>
                }
                else
                {
                    <ol class="recent-visit-list">
                        @foreach (var visit in recentVisits.Items)
                        {
                            var canCancel = visit.AllowedActions.IsAllowed(VisitActionKeys.Cancel);
                            var hasCancellationPermission = visit.AllowedActions.TryGet(
                                VisitActionKeys.Cancel,
                                out var cancellationPermission);
                            var cancelVisitForm = Model.CancelVisitForms.SingleOrDefault(form =>
                                form.Input.VisitId == visit.VisitId);
                            <li class="recent-visit-row"
                                data-visit-id="@visit.VisitId"
                                data-visit-status="@visit.Status.ToString().ToLowerInvariant()"
                                data-can-cancel="@canCancel.ToString().ToLowerInvariant()">
                                <header class="recent-visit-row-header">
                                    <div>
                                        <p class="recent-visit-kind">@VisitKindLabel(visit.VisitKind)</p>
                                        <h4>@VisitContextLabel(visit)</h4>
                                    </div>
                                    <span class="status-chip @(visit.Status == ClientVisitRowStatus.Active ? "status-active" : "status-canceled")">
                                        @(visit.Status == ClientVisitRowStatus.Active ? "Active" : "Canceled")
                                    </span>
                                </header>

                                <dl class="recent-visit-meta">
                                    <div>
                                        <dt>Occurred</dt>
                                        <dd>@visit.OccurredAt.UtcDateTime.ToString("yyyy-MM-dd HH:mm") UTC</dd>
                                    </div>
                                    <div>
                                        <dt>Recorded</dt>
                                        <dd>@visit.RecordedAt.UtcDateTime.ToString("yyyy-MM-dd HH:mm") UTC</dd>
                                    </div>
                                    @if (visit.EntryOrigin != EntryOrigin.Normal)
                                    {
                                        <div>
                                            <dt>Source</dt>
                                            <dd><span class="source-label">@EntryOriginLabel(visit.EntryOrigin)</span></dd>
                                        </div>
                                    }
                                </dl>

                                @if (!string.IsNullOrWhiteSpace(visit.Comment))
                                {
                                    <p class="recent-visit-comment">@visit.Comment</p>
                                }

                                @if (visit.Cancellation is { } cancellation)
                                {
                                    <div class="recent-visit-cancellation">
                                        <strong>Cancellation</strong>
                                        <span>@cancellation.Reason</span>
                                        <span>
                                            @cancellation.RecordedAt.UtcDateTime.ToString("yyyy-MM-dd HH:mm") UTC
                                            @if (cancellation.EntryOrigin != EntryOrigin.Normal)
                                            {
                                                <span class="source-label">@EntryOriginLabel(cancellation.EntryOrigin)</span>
                                            }
                                        </span>
                                    </div>
                                }
                                else if (canCancel && cancelVisitForm is not null)
                                {
                                    <partial name="_CancelVisitForm" model="cancelVisitForm" />
                                }
                                else if (hasCancellationPermission)
                                {
                                    <p class="recent-visit-permission @(canCancel ? "permission-allowed" : "permission-restricted")"
                                       data-visit-cancel-permission>
                                        @(canCancel
                                            ? "Cancellation action unavailable; refresh the profile."
                                            : cancellationPermission.DeniedReason ?? "Cancellation restricted")
                                    </p>
                                }
                            </li>
                        }
                    </ol>
                }
            </section>
        }

        @if (profile.RecentPayments is { } recentPayments)
        {
            <section class="recent-payments" aria-labelledby="recent-payments-title">
                <header class="recent-payments-header">
                    <h3 id="recent-payments-title">Recent payments</h3>
                    @if (recentPayments.HasMore)
                    {
                        <span class="result-count">Latest @recentPayments.Items.Count</span>
                    }
                </header>

                @if (recentPayments.Items.Count == 0)
                {
                    <p class="recent-payments-empty">No payments recorded</p>
                }
                else
                {
                    <ol class="recent-payment-list">
                        @foreach (var payment in recentPayments.Items)
                        {
                            <li class="recent-payment-row"
                                data-payment-id="@payment.PaymentId"
                                data-payment-status="@payment.Status.ToString().ToLowerInvariant()">
                                <header class="recent-payment-row-header">
                                    <div>
                                        <p class="recent-payment-context">@PaymentContextLabel(payment.PaymentContext)</p>
                                        <h4>@MoneyLabel(payment.Amount)</h4>
                                    </div>
                                    <span class="status-chip @PaymentStatusClass(payment.Status)">
                                        @PaymentStatusLabel(payment.Status)
                                    </span>
                                </header>

                                <dl class="recent-payment-meta">
                                    <div>
                                        <dt>Method</dt>
                                        <dd>@PaymentMethodLabel(payment.Method)</dd>
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(payment.MembershipTypeNameSnapshot))
                                    {
                                        <div>
                                            <dt>Membership</dt>
                                            <dd>@payment.MembershipTypeNameSnapshot</dd>
                                        </div>
                                    }
                                    <div>
                                        <dt>Occurred</dt>
                                        <dd>@payment.OccurredAt.UtcDateTime.ToString("yyyy-MM-dd HH:mm") UTC</dd>
                                    </div>
                                    <div>
                                        <dt>Recorded</dt>
                                        <dd>@payment.RecordedAt.UtcDateTime.ToString("yyyy-MM-dd HH:mm") UTC</dd>
                                    </div>
                                    @if (payment.EntryOrigin != EntryOrigin.Normal)
                                    {
                                        <div>
                                            <dt>Source</dt>
                                            <dd><span class="source-label">@EntryOriginLabel(payment.EntryOrigin)</span></dd>
                                        </div>
                                    }
                                </dl>

                                @if (!string.IsNullOrWhiteSpace(payment.Comment))
                                {
                                    <p class="recent-payment-comment">@payment.Comment</p>
                                }

                                @if (payment.Cancellation is { } paymentCancellation)
                                {
                                    <div class="recent-payment-cancellation">
                                        <strong>Cancellation</strong>
                                        <span>@paymentCancellation.Reason</span>
                                        <span>
                                            @paymentCancellation.RecordedAt.UtcDateTime.ToString("yyyy-MM-dd HH:mm") UTC
                                            @if (paymentCancellation.EntryOrigin != EntryOrigin.Normal)
                                            {
                                                <span class="source-label">@EntryOriginLabel(paymentCancellation.EntryOrigin)</span>
                                            }
                                        </span>
                                    </div>
                                }

                                @if (payment.CorrectionFromOriginal is { } correctionFromOriginal)
                                {
                                    <div class="recent-payment-correction correction-incoming"
                                         data-original-payment-id="@correctionFromOriginal.OriginalPaymentId"
                                         data-replacement-payment-id="@correctionFromOriginal.ReplacementPaymentId">
                                        <strong>Corrected replacement</strong>
                                        <span>This payment replaces the original cash entry.</span>
                                        <span>@correctionFromOriginal.Reason</span>
                                        <span>Changed: @ChangedFieldsLabel(correctionFromOriginal.ChangedFields)</span>
                                        <span>
                                            @correctionFromOriginal.RecordedAt.UtcDateTime.ToString("yyyy-MM-dd HH:mm") UTC
                                            @if (correctionFromOriginal.EntryOrigin != EntryOrigin.Normal)
                                            {
                                                <span class="source-label">@EntryOriginLabel(correctionFromOriginal.EntryOrigin)</span>
                                            }
                                        </span>
                                    </div>
                                }

                                @if (payment.CorrectionToReplacement is { } correctionToReplacement)
                                {
                                    <div class="recent-payment-correction correction-outgoing"
                                         data-original-payment-id="@correctionToReplacement.OriginalPaymentId"
                                         data-replacement-payment-id="@correctionToReplacement.ReplacementPaymentId">
                                        <strong>Replaced payment</strong>
                                        <span>This original cash entry was replaced by a correction.</span>
                                        <span>@correctionToReplacement.Reason</span>
                                        <span>Changed: @ChangedFieldsLabel(correctionToReplacement.ChangedFields)</span>
                                        <span>
                                            @correctionToReplacement.RecordedAt.UtcDateTime.ToString("yyyy-MM-dd HH:mm") UTC
                                            @if (correctionToReplacement.EntryOrigin != EntryOrigin.Normal)
                                            {
                                                <span class="source-label">@EntryOriginLabel(correctionToReplacement.EntryOrigin)</span>
                                            }
                                        </span>
                                    </div>
                                }

                                @if (correctPaymentFormsByPaymentId.TryGetValue(
                                    payment.PaymentId,
                                    out var correctPaymentForm))
                                {
                                    <partial name="_CorrectPaymentForm" model="correctPaymentForm" />
                                }
                            </li>
                        }
                    </ol>
                }
            </section>
        }

        @if (Model.UpdateClientForm is not null)
        {
            <partial name="_UpdateClientForm" model="Model.UpdateClientForm" />
        }

        @if (Model.CardAssignmentForm is not null)
        {
            <partial name="_CardAssignmentForm" model="Model.CardAssignmentForm" />
        }
    }
</section>

@functions {
    private static string WarningLabel(string code)
    {
        return code switch
        {
            "client_inactive" => "Inactive client",
            "no_current_card" => "No current card",
            _ => "Attention",
        };
    }

    private static string VisitKindLabel(VisitKind visitKind)
    {
        return visitKind switch
        {
            VisitKind.Membership => "Membership visit",
            VisitKind.OneOff => "One-off visit",
            VisitKind.Trial => "Trial visit",
            _ => "Visit",
        };
    }

    private static string VisitContextLabel(ClientVisitRow visit)
    {
        return visit.Consumption?.MembershipTypeNameSnapshot
            ?? VisitKindLabel(visit.VisitKind);
    }

    private static string EntryOriginLabel(EntryOrigin entryOrigin)
    {
        return entryOrigin switch
        {
            EntryOrigin.Normal => "Normal",
            EntryOrigin.ManualBackfill => "Manual backfill",
            EntryOrigin.PaperFallback => "Paper fallback",
            EntryOrigin.FutureImport => "Future import",
            _ => "Unknown source",
        };
    }

    private static string MoneyLabel(Money money)
    {
        return FormattableString.Invariant($"{money.Amount:0.##} {money.Currency}");
    }

    private static string PaymentMethodLabel(PaymentMethod method)
    {
        return method switch
        {
            PaymentMethod.Cash => "Cash",
            _ => "Unknown method",
        };
    }

    private static string PaymentContextLabel(PaymentContext paymentContext)
    {
        return paymentContext switch
        {
            PaymentContext.MembershipSale => "Membership sale",
            PaymentContext.OneOff => "One-off payment",
            PaymentContext.Trial => "Trial payment",
            PaymentContext.NegativeClosure => "Negative closure",
            PaymentContext.Other => "Other payment",
            _ => "Payment",
        };
    }

    private static string PaymentStatusClass(ClientPaymentRowStatus status)
    {
        return status switch
        {
            ClientPaymentRowStatus.Active => "status-active",
            ClientPaymentRowStatus.Canceled => "status-canceled",
            ClientPaymentRowStatus.Replaced => "status-replaced",
            _ => "status-inactive",
        };
    }

    private static string MembershipStatusClass(string status)
    {
        return status switch
        {
            ClientMembershipSummaryStatusCodes.Active => "status-active",
            ClientMembershipSummaryStatusCodes.Canceled => "status-canceled",
            ClientMembershipSummaryStatusCodes.Corrected => "status-corrected",
            _ => "status-inactive",
        };
    }

    private static string MembershipStatusLabel(string status)
    {
        return status switch
        {
            ClientMembershipSummaryStatusCodes.Active => "Active",
            ClientMembershipSummaryStatusCodes.Expired => "Expired",
            ClientMembershipSummaryStatusCodes.Canceled => "Canceled",
            ClientMembershipSummaryStatusCodes.Corrected => "Corrected",
            _ => "Unknown",
        };
    }

    private static string ExtensionSourceKindCode(MembershipExtensionSourceKind sourceKind)
    {
        return sourceKind switch
        {
            MembershipExtensionSourceKind.Freeze => "freeze",
            MembershipExtensionSourceKind.NonWorkingDay => "non-working-day",
            _ => "unknown",
        };
    }

    private static string ExtensionSourceKindLabel(MembershipExtensionSourceKind sourceKind)
    {
        return sourceKind switch
        {
            MembershipExtensionSourceKind.Freeze => "Freeze",
            MembershipExtensionSourceKind.NonWorkingDay => "Non-working day",
            _ => "Unknown source",
        };
    }

    private static string ExtensionSourceStatusCode(MembershipExtensionSourceStatus status)
    {
        return status.ToString().ToLowerInvariant();
    }

    private static string ExtensionSourceStatusClass(MembershipExtensionSourceStatus status)
    {
        return status switch
        {
            MembershipExtensionSourceStatus.Active => "status-active",
            MembershipExtensionSourceStatus.Canceled => "status-canceled",
            MembershipExtensionSourceStatus.Corrected => "status-corrected",
            _ => "status-inactive",
        };
    }

    private static string ExtensionStatusRowClass(MembershipExtensionSourceStatus status)
    {
        return status switch
        {
            MembershipExtensionSourceStatus.Active => "extension-status-active",
            MembershipExtensionSourceStatus.Canceled => "extension-status-canceled",
            MembershipExtensionSourceStatus.Corrected => "extension-status-corrected",
            _ => "extension-status-inactive",
        };
    }

    private static string ExtensionSourceStatusLabel(MembershipExtensionSourceStatus status)
    {
        return status switch
        {
            MembershipExtensionSourceStatus.Active => "Active",
            MembershipExtensionSourceStatus.Canceled => "Canceled",
            MembershipExtensionSourceStatus.Corrected => "Corrected",
            _ => "Unknown",
        };
    }

    private static string PaymentStatusLabel(ClientPaymentRowStatus status)
    {
        return status switch
        {
            ClientPaymentRowStatus.Active => "Active",
            ClientPaymentRowStatus.Canceled => "Canceled",
            ClientPaymentRowStatus.Replaced => "Replaced",
            _ => "Unknown",
        };
    }

    private static string ChangedFieldsLabel(IReadOnlyList<string> changedFields)
    {
        return string.Join(", ", changedFields.Select(ChangedFieldLabel));
    }

    private static string ChangedFieldLabel(string changedField)
    {
        return changedField switch
        {
            "amount" => "amount",
            "occurred_at" => "occurred time",
            "payment_context" => "context",
            "membership_id" => "membership",
            "comment" => "comment",
            _ => changedField.Replace('_', ' '),
        };
    }
}
