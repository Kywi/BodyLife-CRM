@model MarkVisitFormViewModel
@using BodyLife.Crm.Web.Localization
@inject Microsoft.Extensions.Localization.IStringLocalizer<global::BodyLife.Crm.Web.Localization.Reception> L
@{
    var input = Model.Input;
    var options = Model.Options;
    var clientKey = input.ClientId.ToString("N");
    var selectedAcknowledgements = (input.Acknowledgements ?? []).ToHashSet();
    var hasSelectableMembership = options?.MembershipOptions.Any(option => option.CanSelect) == true;
    var hasSelectedMembership = input.VisitKind == VisitKind.Membership
        && options?.MembershipOptions.Any(option =>
            option.MembershipId == input.MembershipId && option.CanSelect) == true;
    var canSubmit = input.VisitKind is VisitKind.OneOff or VisitKind.Trial
        || hasSelectedMembership;
}

<details id="mark-visit-action-panel"
         class="profile-action-panel"
         open="@(Model.IsOpen ? "open" : null)">
    <summary>@L["Visit.Mark"]</summary>
    <div class="profile-action-content">
        @if (Model.Errors.Count > 0)
        {
            <div class="command-error-summary" role="alert">
                <strong>@L["Visit.NotMarked"]</strong>
                <ul>
                    @foreach (var message in Model.Errors.Select(error => ReceptionCommandErrorLocalizer.Display(L, error)).Distinct(StringComparer.Ordinal))
                    {
                        <li>@message</li>
                    }
                </ul>
            </div>
        }

        @if (!Model.IsAvailable || options is null)
        {
            <div class="warning-block warning-danger" role="alert">
                <strong>@L["Visit.ActionUnavailable"]</strong>
                <span>@L["Error.Generic"]</span>
            </div>
        }
        else
        {
            <form id="mark-visit-form-@clientKey"
                  class="mark-visit-form"
                  method="post"
                  asp-page="/Reception/Index"
                  asp-page-handler="MarkVisit"
                  data-busy-form
                  data-mark-visit-form
                  hx-post="@Url.Page("/Reception/Index", "MarkVisit")"
                  hx-target="#mark-visit-action-panel"
                  hx-swap="outerHTML"
                  hx-sync="this:drop"
                  hx-indicator="#mark-visit-loading"
                  hx-disabled-elt="find button">
                <input type="hidden" name="form.ClientId" value="@input.ClientId" />
                <input type="hidden" name="form.OccurredAt" value="@options.OccurredAt.ToString("O")" />
                <input type="hidden" name="form.IdempotencyKey" value="@input.IdempotencyKey" />
                <input type="hidden" name="form.SearchQuery" value="@input.SearchQuery" />
                <input type="hidden" name="form.SearchMode" value="@input.SearchMode" />
                <input type="hidden" name="form.SearchIncludeInactive" value="@input.SearchIncludeInactive.ToString().ToLowerInvariant()" />
                <input type="hidden" name="form.SearchPageCursor" value="@input.SearchPageCursor" />

                <dl class="visit-business-context">
                    <div>
                        <dt>@L["Visit.Date"]</dt>
                        <dd>@ReceptionDisplayFormatter.Date(options.VisitDate)</dd>
                    </div>
                    <div>
                        <dt>@L["Visit.RecordedAs"]</dt>
                        <dd>@ReceptionDisplayFormatter.Time(options.OccurredAt)</dd>
                    </div>
                </dl>

                <fieldset class="visit-kind-control">
                    <legend>@L["Visit.Type"]</legend>
                    <div class="visit-kind-options">
                        <label>
                            <input type="radio"
                                   name="form.VisitKind"
                                   value="@VisitKind.Membership"
                                   data-visit-kind="membership"
                                   checked="@(input.VisitKind == VisitKind.Membership ? "checked" : null)"
                                   disabled="@(!hasSelectableMembership ? "disabled" : null)"
                                   required />
                            <span>@L["Field.Membership"]</span>
                        </label>
                        <label>
                            <input type="radio"
                                   name="form.VisitKind"
                                   value="@VisitKind.OneOff"
                                   data-visit-kind="one-off"
                                   checked="@(input.VisitKind == VisitKind.OneOff ? "checked" : null)"
                                   required />
                            <span>@L["Visit.OneOff"]</span>
                        </label>
                        <label>
                            <input type="radio"
                                   name="form.VisitKind"
                                   value="@VisitKind.Trial"
                                   data-visit-kind="trial"
                                   checked="@(input.VisitKind == VisitKind.Trial ? "checked" : null)"
                                   required />
                            <span>@L["Visit.Trial"]</span>
                        </label>
                    </div>
                </fieldset>

                @if (options.MembershipOptions.Count == 0)
                {
                    <p class="visit-membership-empty">
                        @L["Visit.NoActiveMemberships"]
                    </p>
                }
                else
                {
                    <fieldset class="visit-membership-choices">
                        <legend>@L["Visit.MembershipChoice"]</legend>
                        <div class="visit-membership-list">
                            @foreach (var membership in options.MembershipOptions)
                            {
                                var membershipKey = membership.MembershipId.ToString("N");
                                var isSelected = input.MembershipId == membership.MembershipId;
                                var acknowledgementInputsActive = input.VisitKind == VisitKind.Membership
                                    && isSelected
                                    && membership.CanSelect;

                                <div class="visit-membership-option @(membership.CanSelect ? null : "visit-membership-blocked")"
                                     data-visit-membership-option="@membershipKey">
                                    <label class="visit-membership-choice">
                                        <input type="radio"
                                               name="form.MembershipId"
                                               value="@membership.MembershipId"
                                               data-visit-membership-choice
                                               data-membership-id="@membershipKey"
                                               checked="@(isSelected ? "checked" : null)"
                                               disabled="@(!membership.CanSelect ? "disabled" : null)" />
                                        <span>
                                            <strong>@membership.TypeName</strong>
                                            <small>
                                                @ReceptionDisplayFormatter.Date(membership.StartDate) @L["Range.To"]
                                                @ReceptionDisplayFormatter.Date(membership.EffectiveEndDate)
                                            </small>
                                        </span>
                                    </label>

                                    <dl class="visit-membership-meta">
                                        <div>
                                            <dt>@L["Visit.Remaining"]</dt>
                                            <dd>@membership.RemainingVisits</dd>
                                        </div>
                                        <div>
                                            <dt>@L["Visit.Eligibility"]</dt>
                                            <dd>@EligibilityLabel(membership.EligibilityStatus)</dd>
                                        </div>
                                    </dl>

                                    @if (!membership.CanSelect)
                                    {
                                        <div class="warning-block warning-danger">
                                            <strong>@L["Visit.MembershipBlocked"]</strong>
                                            <span>@EligibilityMessage(membership.EligibilityStatus)</span>
                                        </div>
                                    }

                                    @foreach (var warning in membership.Warnings)
                                    {
                                        <div class="warning-block @WarningClass(warning.Severity)">
                                            <strong>@WarningTitle(warning.Code)</strong>
                                            <span>@WarningMessage(warning.Code)</span>
                                        </div>
                                    }

                                    @if (membership.RequiredAcknowledgements.Count > 0)
                                    {
                                        <div class="visit-acknowledgement-list"
                                             data-visit-acknowledgements="@membershipKey"
                                             data-active="@(acknowledgementInputsActive ? "true" : "false")">
                                            @foreach (var acknowledgement in membership.RequiredAcknowledgements)
                                            {
                                                var acknowledgementKey = $"visit-ack-{membershipKey}-{acknowledgement}";
                                                <label class="acknowledgement-control" for="@acknowledgementKey">
                                                    <input id="@acknowledgementKey"
                                                           type="checkbox"
                                                           name="form.Acknowledgements"
                                                           value="@acknowledgement"
                                                           data-visit-acknowledgement
                                                           checked="@(selectedAcknowledgements.Contains(acknowledgement) && isSelected ? "checked" : null)"
                                                           disabled="@(!acknowledgementInputsActive ? "disabled" : null)"
                                                           required="@(acknowledgementInputsActive ? "required" : null)" />
                                                    <span>@AcknowledgementLabel(acknowledgement)</span>
                                                </label>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </fieldset>
                }

                <div class="form-field">
                    <label for="visit-comment-@clientKey">@L["Field.CommentOptional"]</label>
                    <textarea id="visit-comment-@clientKey"
                              name="form.Comment"
                              maxlength="1000">@input.Comment</textarea>
                </div>

                <div class="action-form-footer">
                    <span id="mark-visit-loading"
                          class="request-indicator htmx-indicator"
                          role="status"
                          aria-live="polite">@L["Visit.Marking"]</span>
                    <button type="submit"
                            data-mark-visit-submit
                            data-busy-text="@L["Visit.MarkingShort"]"
                            disabled="@(!canSubmit ? "disabled" : null)">@L["Visit.Mark"]</button>
                </div>
            </form>
        }
    </div>
</details>

@functions {
    private string EligibilityLabel(MembershipVisitEligibilityStatus status)
    {
        return status switch
        {
            MembershipVisitEligibilityStatus.Eligible => L["Visit.Eligibility.Selectable"],
            MembershipVisitEligibilityStatus.BeforeMembershipStart => L["Visit.Eligibility.FutureStart"],
            MembershipVisitEligibilityStatus.DuringActiveFreeze => L["Visit.Eligibility.FrozenDate"],
            MembershipVisitEligibilityStatus.MembershipInactive => L["Status.Inactive"],
            _ => L["Status.Unavailable"],
        };
    }

    private string EligibilityMessage(MembershipVisitEligibilityStatus status)
    {
        return status switch
        {
            MembershipVisitEligibilityStatus.BeforeMembershipStart =>
                L["Visit.Eligibility.BeforeStart.Message"],
            MembershipVisitEligibilityStatus.DuringActiveFreeze =>
                L["Visit.Eligibility.Frozen.Message"],
            MembershipVisitEligibilityStatus.MembershipInactive =>
                L["Visit.Eligibility.Inactive.Message"],
            _ => L["Visit.Eligibility.Unavailable.Message"],
        };
    }

    private static string WarningClass(MembershipWarningSeverity severity)
    {
        return severity == MembershipWarningSeverity.Danger
            ? "warning-danger"
            : "warning-caution";
    }

    private string WarningTitle(string code)
    {
        return code switch
        {
            MembershipWarningCodes.NegativeBalance => L["Warning.NegativeBalance.Title"],
            MembershipWarningCodes.ExpiredByDate => L["Warning.Expired.Title"],
            MembershipWarningCodes.ZeroRemaining => L["Warning.ZeroRemaining.Title"],
            MembershipWarningCodes.EndingSoon => L["Warning.EndingSoon.Title"],
            MembershipWarningCodes.LowRemaining => L["Warning.LowRemaining.Title"],
            _ => L["Warning.Attention"],
        };
    }

    private string WarningMessage(string code)
    {
        return code switch
        {
            MembershipWarningCodes.NegativeBalance => L["Warning.NegativeBalance.Message"],
            MembershipWarningCodes.ExpiredByDate => L["Warning.Expired.Message"],
            MembershipWarningCodes.ZeroRemaining => L["Warning.ZeroRemaining.Message"],
            MembershipWarningCodes.EndingSoon => L["Warning.EndingSoon.Message"],
            MembershipWarningCodes.LowRemaining => L["Warning.LowRemaining.Message"],
            _ => L["Warning.Generic.Message"],
        };
    }

    private string AcknowledgementLabel(MembershipVisitAcknowledgement acknowledgement)
    {
        return acknowledgement switch
        {
            MembershipVisitAcknowledgement.Expired =>
                L["Visit.Acknowledge.Expired"],
            MembershipVisitAcknowledgement.ZeroRemaining =>
                L["Visit.Acknowledge.ZeroRemaining"],
            MembershipVisitAcknowledgement.NegativeRemaining =>
                L["Visit.Acknowledge.Negative"],
            _ => L["Visit.Acknowledge.Generic"],
        };
    }
}
