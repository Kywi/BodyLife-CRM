@model ReceptionWorkspaceViewModel
@using BodyLife.Crm.Web.Localization
@inject Microsoft.Extensions.Localization.IStringLocalizer<Reception> L
@inject Microsoft.Extensions.Localization.IStringLocalizer<Shared> SharedL
@{
    var searchResult = Model.SearchResult;
}

<section id="reception-workspace" class="reception-workspace">
    <section class="search-results-region" aria-label="@L["Workspace.SearchResults"]" aria-live="polite">
        <header class="region-header">
            <h2>@L["Workspace.SearchResults"]</h2>
            @if (searchResult is { Status: SearchClientsStatus.Success })
            {
                var matchCount = searchResult.Items.Count;
                <span class="result-count">@string.Format(System.Globalization.CultureInfo.CurrentCulture, L["Workspace.MatchCount"], matchCount)</span>
            }
        </header>

        @if (searchResult is null)
        {
            <div class="operational-empty">
                <strong>@L["Workspace.Ready"]</strong>
            </div>
        }
        else if (searchResult.Status != SearchClientsStatus.Success)
        {
            <div class="warning-block warning-danger" role="alert">
                <strong>@L["Workspace.Unavailable"]</strong>
                <span>@L["Error.Generic"]</span>
            </div>
        }
        else if (searchResult.Items.Count == 0)
        {
            <div class="operational-empty no-search-results">
                <strong>@L["Workspace.Empty"]</strong>
            </div>

            @if (Model.CreateClientForm is not null)
            {
                <partial name="_CreateClientForm" model="Model.CreateClientForm" />
            }
        }
        else
        {
            <div class="client-result-list">
                @foreach (var item in searchResult.Items)
                {
                    var fullProfileUrl = Url.Page(
                        "/Reception/Index",
                        values: new
                        {
                            q = Model.Query,
                            mode = Model.Mode,
                            includeInactive = Model.IncludeInactive,
                            pageCursor = Model.PageCursor,
                            clientId = item.ClientId,
                        });
                    var htmxProfileUrl = Url.Page(
                        "/Reception/Index",
                        "Profile",
                        new
                        {
                            q = Model.Query,
                            mode = Model.Mode,
                            includeInactive = Model.IncludeInactive,
                            pageCursor = Model.PageCursor,
                            clientId = item.ClientId,
                        });

                    <a class="client-result-row"
                       href="@fullProfileUrl"
                       aria-label="@string.Format(System.Globalization.CultureInfo.CurrentCulture, L["Workspace.OpenClient"], item.DisplayName)"
                       hx-get="@htmxProfileUrl"
                       hx-target="#client-profile"
                       hx-swap="outerHTML show:top"
                       hx-sync="#client-profile:replace"
                       hx-indicator="#profile-loading">
                        <header class="client-result-header">
                            <h3>@item.DisplayName</h3>
                            <span class="status-chip @OperationalStatusClass(item.OperationalStatus)">
                                @OperationalStatusLabel(item.OperationalStatus)
                            </span>
                        </header>

                        <dl class="client-result-meta">
                            <div>
                                <dt>@L["Field.Card"]</dt>
                                <dd>@(item.CurrentCardNumber ?? L["Value.NoCurrentCard"])</dd>
                            </div>
                            <div>
                                <dt>@L["Field.Phone"]</dt>
                                <dd>@(item.Phone ?? L["Value.NoPhone"])</dd>
                            </div>
                        </dl>

                        <div class="client-result-summary">
                            <span class="match-chip">@MatchTypeLabel(item.MatchType)</span>
                            @if (item.CurrentMembership is null)
                            {
                                <span class="membership-compact">@L["Value.NoCurrentMembership"]</span>
                            }
                            else
                            {
                                <span class="membership-compact">
                                    @MembershipStatusLabel(item.CurrentMembership.Status) / @WebPluralizer.Visits(SharedL, item.CurrentMembership.RemainingVisits) /
                                    @L["Workspace.Through"] @ReceptionDisplayFormatter.Date(item.CurrentMembership.EffectiveEndDate)
                                </span>
                            }
                        </div>

                        @if (item.Warnings.Count > 0)
                        {
                            <ul class="warning-chip-list" aria-label="@L["Workspace.ClientWarnings"]">
                                @foreach (var warning in item.Warnings)
                                {
                                    <li>@WarningMessage(warning.Code)</li>
                                }
                            </ul>
                        }
                    </a>
                }
            </div>

            @if (searchResult.NextPageCursor is not null)
            {
                var nextPageUrl = Url.Page(
                    "/Reception/Index",
                    values: new
                    {
                        q = Model.Query,
                        mode = Model.Mode,
                        includeInactive = Model.IncludeInactive,
                        pageCursor = searchResult.NextPageCursor,
                    });
                var nextPageHtmxUrl = Url.Page(
                    "/Reception/Index",
                    "Search",
                    new
                    {
                        q = Model.Query,
                        mode = Model.Mode,
                        includeInactive = Model.IncludeInactive,
                        pageCursor = searchResult.NextPageCursor,
                    });

                <a class="secondary-link result-page-link"
                   href="@nextPageUrl"
                   hx-get="@nextPageHtmxUrl"
                   hx-target="#reception-workspace"
                   hx-swap="outerHTML"
                   hx-sync="#reception-search:replace"
                   hx-indicator="#search-loading">@L["Action.MoreResults"]</a>
            }
        }
    </section>

    <partial name="_ClientProfile" model="Model.Profile" />
</section>

@functions {
    private static string OperationalStatusClass(ClientOperationalStatus status)
    {
        return status == ClientOperationalStatus.Active
            ? "status-active"
            : "status-inactive";
    }

    private string OperationalStatusLabel(ClientOperationalStatus status)
    {
        return status == ClientOperationalStatus.Active
            ? L["Status.Active"]
            : L["Status.Inactive"];
    }

    private string MatchTypeLabel(ClientSearchMatchType matchType)
    {
        return matchType switch
        {
            ClientSearchMatchType.ExactCard => L["Match.ExactCard"],
            ClientSearchMatchType.ExactPhone => L["Match.ExactPhone"],
            ClientSearchMatchType.PhoneLastFour => L["Match.PhoneLastFour"],
            ClientSearchMatchType.ExactName => L["Match.ExactName"],
            ClientSearchMatchType.PartialCard => L["Match.PartialCard"],
            ClientSearchMatchType.PartialPhone => L["Match.PartialPhone"],
            ClientSearchMatchType.PartialName => L["Match.PartialName"],
            _ => L["Match.Generic"],
        };
    }

    private string MembershipStatusLabel(string status)
    {
        return status switch
        {
            ClientMembershipSummaryStatusCodes.Active => L["Status.Active"],
            ClientMembershipSummaryStatusCodes.Expired => L["Status.Expired"],
            ClientMembershipSummaryStatusCodes.Canceled => L["Status.Canceled"],
            ClientMembershipSummaryStatusCodes.Corrected => L["Status.Corrected"],
            _ => L["Value.Unknown"],
        };
    }

    private string WarningMessage(string code)
    {
        return code switch
        {
            "client_inactive" => L["Warning.ClientInactive.Message"],
            "no_current_card" => L["Warning.NoCurrentCard.Message"],
            _ => L["Warning.Generic.Message"],
        };
    }
}
